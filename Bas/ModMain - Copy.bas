 sql = sql & " RETURNS Float" & Chr(13)
sql = sql & "  AS" & Chr(13)
 sql = sql & "Begin" & Chr(13)
 sql = sql & "RETURN (" & Chr(13)
sql = sql & "SELECT     SUM(dbo.Transaction_Details.ShowQty) AS totalqty" & Chr(13)
sql = sql & "FROM         dbo.Transactions INNER JOIN" & Chr(13)
sql = sql & "dbo.Transaction_Details ON dbo.Transactions.Transaction_ID = dbo.Transaction_Details.Transaction_ID" & Chr(13)
sql = sql & "Where (dbo.Transactions.Transaction_Type = 19) And (dbo.Transactions.BillBasedOn = 2)" & Chr(13)
sql = sql & "GROUP BY dbo.Transactions.order_no, dbo.Transaction_Details.Item_ID" & Chr(13)
sql = sql & "HAVING      (dbo.Transactions.order_no = @order_no ) AND (dbo.Transaction_Details.Item_ID = @itemID)" & Chr(13)
sql = sql & ")" & Chr(13)
 sql = sql & "End" & Chr(13)
 
    db_createOrUpdateFuctionSQL "RetriveRecivedQty", sql
    
    
    
