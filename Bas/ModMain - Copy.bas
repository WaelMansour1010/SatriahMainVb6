       New_View = " SELECT     TOP 100 PERCENT QryTransactionsTotal.Transaction_ID, QryTransactionsTotal.Transaction_Date, dbo.TblCustemers.CusName, dbo.TblStore.StoreName, "
  New_View = New_View & "                     QryTransactionsTotal.Trans_DiscountType, QryTransactionsTotal.Trans_Discount, QryTransactionsTotal.Transaction_Serial, QryTransactionsTotal.PaymentType,"
  New_View = New_View & "                      QryTransactionsTotal.CusID, QryTransactionsTotal.TaxFound, QryTransactionsTotal.TaxValue, QryTransactionsTotal.TransSum, QryTransactionsTotal.TotalAfterTax,"
  New_View = New_View & "                      QryTransactionsTotal.TransNet, QryTransactionsTotal.Transaction_Type, dbo.TblBoxesData.BoxID, dbo.TblBoxesData.BoxName, QryTransactionsTotal.StoreID,"
  New_View = New_View & "                      QryTransactionsTotal.Emp_id , dbo.TblEmployee.emp_Name, dbo.Transactions.NoteSerial, dbo.Transactions.NoteSerial1"
  New_View = New_View & "   FROM         dbo.Transactions INNER JOIN"
  New_View = New_View & "                      dbo.TblStore INNER JOIN"
  New_View = New_View & "                      dbo.QryTransactionsTotal() QryTransactionsTotal ON dbo.TblStore.StoreID = QryTransactionsTotal.StoreID ON"
  New_View = New_View & "                      dbo.Transactions.Transaction_ID = QryTransactionsTotal.Transaction_ID INNER JOIN"
  New_View = New_View & "                      dbo.TblEmployee ON QryTransactionsTotal.Emp_ID = dbo.TblEmployee.Emp_ID LEFT OUTER JOIN"
  New_View = New_View & "                      dbo.TblCustemers ON QryTransactionsTotal.CusID = dbo.TblCustemers.CusID LEFT OUTER JOIN"
  New_View = New_View & "                      dbo.QryNotesBoxes ON QryTransactionsTotal.Transaction_ID = dbo.QryNotesBoxes.Transaction_ID LEFT OUTER JOIN"
  New_View = New_View & "                      dbo.TblBoxesData ON dbo.QryNotesBoxes.BoxID = dbo.TblBoxesData.BoxID"
  New_View = New_View & "     WHERE     (QryTransactionsTotal.Transaction_Type = 2 OR"
  New_View = New_View & "                      QryTransactionsTotal.Transaction_Type = 21)"
  New_View = New_View & "         ORDER BY QryTransactionsTotal.Transaction_Date"
