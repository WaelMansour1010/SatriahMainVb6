    sql = sql & "  RETURNS integer     AS    Begin" & Chr(13)
    sql = sql & "   RETURN (" & Chr(13)
    sql = sql & "SELECT  min(dbo.TblPripaidExpChiled.ID) as idd" & Chr(13)
    sql = sql & "  FROM         dbo.TblPripaidExpensesDet LEFT OUTER JOIN" & Chr(13)
    sql = sql & "                  dbo.TblPripaidExpChiled ON dbo.TblPripaidExpensesDet.ID = dbo.TblPripaidExpChiled.PaidExIDDet" & Chr(13)
     sql = sql & "   WHERE   (dbo.TblPripaidExpChiled.RecDate)= (SELECT     MIN(dbo.TblPripaidExpChiled.RecDate) AS RecDataee" & Chr(13)
     sql = sql & "    FROM         dbo.TblPripaidExpensesDet LEFT OUTER JOIN" & Chr(13)
     sql = sql & "                 dbo.TblPripaidExpChiled ON dbo.TblPripaidExpensesDet.ID = dbo.TblPripaidExpChiled.PaidExIDDet" & Chr(13)
     sql = sql & "    WHERE     (dbo.TblPripaidExpensesDet.PaymentPayed = 1)and (dbo.TblPripaidExpensesDet.EmpID = @EmpID ) and (dbo.TblPripaidExpChiled.PerolPaed IS NULL )  AND dbo.TblPripaidExpensesDet.Messier=1  )and (dbo.TblPripaidExpensesDet.EmpID = @EmpID )" & Chr(13)
    sql = sql & "  )" & Chr(13)
    sql = sql & "  End" & Chr(13)
   
