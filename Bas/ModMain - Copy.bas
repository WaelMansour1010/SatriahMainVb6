    Cn.Execute sql
       sql = " CREATE FUNCTION GetQtyRecevPlanProd(@WorkOrderID as varchar(255) ,@ItemID integer,@FromDate DateTime,@ToDate DateTime,@Transaction_Type integer)  " & Chr(13)
    sql = sql & "         RETURNS float    AS    Begin" & Chr(13)
    sql = sql & "          RETURN (" & Chr(13)
    sql = sql & "       SELECT     SUM(dbo.Transaction_Details.ShowQty) AS Qty"
    sql = sql & "                 FROM         dbo.Transactions INNER JOIN"
    sql = sql & "                   dbo.Transaction_Details ON dbo.Transactions.Transaction_ID = dbo.Transaction_Details.Transaction_ID"
    sql = sql & "         WHERE     (dbo.Transactions.Transaction_Type = @Transaction_Type) AND (dbo.Transaction_Details.Item_ID = @ItemID)"
    sql = sql & "  AND (dbo.Transactions.WorkOrderNO =@WorkOrderID)  AND (dbo.Transactions.Transaction_Date >=@FromDate)AND (dbo.Transactions.Transaction_Date <=@ToDate)"
    sql = sql & " )  End" & Chr(13)
    db_createOrUpdateFuctionSQL "GetQtyRecevPlanProd", sql
    
