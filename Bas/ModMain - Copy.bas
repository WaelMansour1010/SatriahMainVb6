     sql = " CREATE FUNCTION GetPayemntInvoice(@Transactio_ID integer ,@TransTyp integer,@FromDate datetime,@ToDate datetime)  " & Chr(13)
    sql = sql & "         RETURNS float    AS    Begin" & Chr(13)
    sql = sql & "          RETURN (" & Chr(13)
    sql = sql & "        SELECT     SUM(PayedValue) AS SumPayedValue"
    sql = sql & "     From dbo.TblBillBuyPayment2"
    sql = sql & "    Where (Transaction_ID = @Transactio_ID) And (IsNull(TransType, 0) = @TransTyp) and (RecDate>=@FromDate and RecDate<=@ToDate )"
    sql = sql & " )  End" & Chr(13)
