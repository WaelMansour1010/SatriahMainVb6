     sql = "    DROP FUNCTION GetProjectCashing" & Chr(13)
    Cn.Execute sql
 
    sql = "CREATE FUNCTION GetProjectCashing(@fromdate datetime,@Todate datetime ,@project_id as integer)" & Chr(13)
      sql = sql & " RETURNS Float" & Chr(13)
     sql = sql & " AS" & Chr(13)
     sql = sql & " Begin" & Chr(13)
     sql = sql & " RETURN (" & Chr(13)
       sql = sql & " SELECT     SUM(dbo.DOUBLE_ENTREY_VOUCHERS.[Value]) AS TotalCashing" & Chr(13)
    sql = sql & " FROM         dbo.DOUBLE_ENTREY_VOUCHERS INNER JOIN" & Chr(13)
    sql = sql & " dbo.Notes ON dbo.DOUBLE_ENTREY_VOUCHERS.Notes_ID = dbo.Notes.NoteID INNER JOIN" & Chr(13)
    sql = sql & " dbo.ACCOUNTS ON dbo.DOUBLE_ENTREY_VOUCHERS.Account_Code = dbo.ACCOUNTS.Account_Code" & Chr(13)
    sql = sql & " WHERE     (dbo.DOUBLE_ENTREY_VOUCHERS.Credit_Or_Debit = 1) AND (dbo.Notes.NoteType = 4) AND (dbo.Notes.project_id = @project_id)" & Chr(13)
    sql = sql & " AND (dbo.DOUBLE_ENTREY_VOUCHERS.project_id = @project_id or dbo.notes.project_id = @project_id)" & Chr(13)
     sql = sql & " and  ( dbo.DOUBLE_ENTREY_VOUCHERS.RecordDate  >=@fromdate   and dbo.DOUBLE_ENTREY_VOUCHERS.RecordDate  <=@Todate  )" & Chr(13)
 
     sql = sql & " )" & Chr(13)
      sql = sql & " End" & Chr(13)
  
    db_createOrUpdateFuctionSQL "GetProjectCashing", sql

