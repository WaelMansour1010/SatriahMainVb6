    sql = " CREATE FUNCTION GetOrderActualReciveqty(@itemid as integer,@orderno as   varchar(255))" & Chr(13)
    sql = sql & "  RETURNS Float     AS    Begin" & Chr(13)
    sql = sql & "   RETURN (" & Chr(13)
    sql = sql & "  SELECT  sum(   ISNULL(dbo.Transaction_Details.ShowQty, 0)) AS Showqty" & Chr(13)
    sql = sql & "  FROM         dbo.Transactions INNER JOIN" & Chr(13)
    sql = sql & "    dbo.Transaction_Details ON dbo.Transactions.Transaction_ID = dbo.Transaction_Details.Transaction_ID" & Chr(13)
    sql = sql & "  Where (dbo.Transactions.Transaction_Type = 28)" & Chr(13)
    sql = sql & "  AND (dbo.Transaction_Details.Item_ID = @itemid)" & Chr(13)
   ' sql = sql & "  AND (dbo.Transactions.WorkOrderNO = @orderno)" & Chr(13) '
   sql = sql & " AND (dbo.Transactions.WorkOrderNO =  ' ' + @orderno + ' '    )"
    sql = sql & "  )" & Chr(13)
    sql = sql & "  End" & Chr(13)
   
    db_createOrUpdateFuctionSQL "GetOrderActualReciveqty", sql
    
