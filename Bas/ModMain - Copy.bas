    sql = sql & " and  dbo.DOUBLE_ENTREY_VOUCHERS1.RecordDate  =@fromdate and dbo.DOUBLE_ENTREY_VOUCHERS1.Posted IS NULL" & Chr(13)
    sql = sql & " )XTABLE" & Chr(13)
    sql = sql & " )" & Chr(13)
    sql = sql & " End"
