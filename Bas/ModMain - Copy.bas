  sql = sql & "                    dbo.TblEmpAdvance ON dbo.TblEmployee.Emp_ID = dbo.TblEmpAdvance.Emp_ID INNER JOIN" & Chr(13)
  sql = sql & "                    dbo.TblEmpAdvanceDetails ON dbo.TblEmpAdvance.AdvanceID = dbo.TblEmpAdvanceDetails.AdvanceID" & Chr(13)
  sql = sql & "  Where ((Month(dbo.TblEmpAdvanceDetails.PartDate)=@Month AND Year(dbo.TblEmpAdvanceDetails.PartDate)=@Year)" & Chr(13)
  sql = sql & " or (dbo.TblEmpAdvanceDetails.MothID2=@Month AND dbo.TblEmpAdvanceDetails.YearID2=@Year))"
  sql = sql & "  AND( dbo.TblEmpAdvanceDetails.Payed IS NULL  OR (dbo.TblEmpAdvanceDetails.Payed <>1 ))" & Chr(13)
  sql = sql & "  AND dbo.TblEmpAdvance.AdvanceType=0" & Chr(13)
