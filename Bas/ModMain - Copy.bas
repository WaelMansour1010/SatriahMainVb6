sql = sql & "       GroupID int," & Chr(13)
sql = sql & "       ColorID int," & Chr(13)
sql = sql & "       ColorName nvarchar(50)," & Chr(13)
sql = sql & "       itemsize nvarchar(50)" & Chr(13)
  sql = sql & "   " & Chr(13)
sql = sql & "   )" & Chr(13)
sql = sql & "   AS" & Chr(13)
sql = sql & "   " & Chr(13)
sql = sql & "   Begin" & Chr(13)
sql = sql & "       INSERT  @XTable" & Chr(13)
sql = sql & "               SELECT     *" & Chr(13)
sql = sql & "       From" & Chr(13)
sql = sql & "       (" & Chr(13)
sql = sql & "       SELECT     SUM(Qty) AS SumQty, ItemID, ItemCode, ItemName,StoreID,StoreName,GroupID,ColorID,ColorName,ItemSize" & Chr(13)
sql = sql & "                 FROM         (SELECT     TblItems.ItemID, TblItems.ItemCode, TblItems.ItemName, Transactions.StoreID, TblStore.StoreName,TblItems.GroupID,Transaction_Details.ColorID,TblItemsColors.ColorName,Transaction_Details.ItemSize," & Chr(13)
sql = sql & "                            Qty = CASE" & Chr(13)
sql = sql & "                            WHEN Transactions.Transaction_Type = 1 OR" & Chr(13)
sql = sql & "                                                                  " & Chr(13)
sql = sql & "                                                                         Transactions.Transaction_Type = 11 OR" & Chr(13)
sql = sql & "                                                                         Transactions.Transaction_Type = 12 OR" & Chr(13)
sql = sql & "                                                                         Transactions.Transaction_Type = 3 OR" & Chr(13)
sql = sql & "                        Transactions.Transaction_Type = 20 OR" & Chr(13)
                        sql = sql & "   Transactions.Transaction_Type =16 THEN Transaction_Details.Quantity * 1" & Chr(13)
sql = sql & "                           WHEN Transactions.Transaction_Type = 2 OR" & Chr(13)
sql = sql & "                                                                         Transactions.Transaction_Type = 8 OR" & Chr(13)
sql = sql & "                                                                         Transactions.Transaction_Type = 10 OR" & Chr(13)
sql = sql & "                                                                         Transactions.Transaction_Type = 13 OR" & Chr(13)
sql = sql & "                                                                     " & Chr(13)
sql = sql & "   Transactions.Transaction_Type = 17 OR" & Chr(13)
sql = sql & "                          Transactions.Transaction_Type = 18 OR" & Chr(13)
sql = sql & "                       Transactions.Transaction_Type = 19 or" & Chr(13)
sql = sql & "                       Transactions.Transaction_Type =15 THEN Transaction_Details.Quantity * - 1 else 0 END" & Chr(13)
sql = sql & "                                               FROM         dbo.TblStore INNER JOIN" & Chr(13)
sql = sql & "                                 dbo.Transactions ON dbo.TblStore.StoreID = dbo.Transactions.StoreID INNER JOIN" & Chr(13)
sql = sql & "                                 dbo.TblItems INNER JOIN" & Chr(13)
sql = sql & "                                 dbo.Transaction_Details ON dbo.TblItems.ItemID = dbo.Transaction_Details.Item_ID ON" & Chr(13)
sql = sql & "                                 dbo.Transactions.Transaction_ID = dbo.Transaction_Details.Transaction_ID INNER JOIN" & Chr(13)
sql = sql & "                                 dbo.TblItemsColors ON dbo.Transaction_Details.ColorID = dbo.TblItemsColors.ColorID" & Chr(13)
sql = sql & "       Union all" & Chr(13)
sql = sql & "       SELECT     dbo.TblItems.ItemID, dbo.TblItems.ItemCode, dbo.TblItems.ItemName," & Chr(13)
sql = sql & "                         dbo.TblManDetailsReplacedItems.StoreID, dbo.TblStore.StoreName,TblItems.GroupID,1 as ColorID,'' as ColorName,0 as ItemSize," & Chr(13)
sql = sql & "           (dbo.TblManDetailsReplacedItems.ItemQty * dbo.TblManDetailsReplacedItems.ReplaceType) as Qty" & Chr(13)
sql = sql & "   " & Chr(13)
sql = sql & "       FROM         dbo.TblStore INNER JOIN" & Chr(13)
sql = sql & "                         dbo.TblManDetailsReplacedItems ON dbo.TblStore.StoreID = dbo.TblManDetailsReplacedItems.StoreID INNER JOIN" & Chr(13)
sql = sql & "                         dbo.TblItems ON dbo.TblManDetailsReplacedItems.ItemID = dbo.TblItems.ItemID" & Chr(13)
sql = sql & "   " & Chr(13)
sql = sql & "       ) DERIVEDTBL" & Chr(13)
 sql = sql & "                GROUP BY ItemID, ItemCode, ItemName,StoreID,StoreName,GroupID,ColorID,ColorName,ItemSize) YTable" & Chr(13)
sql = sql & "   " & Chr(13)
 sql = sql & "    ORDER BY ItemID" & Chr(13)
