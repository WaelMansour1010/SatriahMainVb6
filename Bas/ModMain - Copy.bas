s = s & " ("

s = s & " @itemid          AS integer,"
s = s & "     @UnitID          AS integer,"
s = s & "     @IsLastPrice     AS BIT"
s = s & " )"
s = s & " RETURNS Float"
s = s & " AS"
s = s & " Begin"
s = s & "     DECLARE @Value AS MONEY"
s = s & "         if @IsLastPrice = 1"
s = s & "             SET @Value ="
s = s & "         ("
s = s & "             SELECT showPrice"
s = s & "             From dbo.Transaction_Details"
s = s & "             WHERE  ("
s = s & "                        ID =("
s = s & "                            SELECT MAX(dbo.Transaction_Details.ID) AS MaxID"
s = s & "                            From dbo.Transaction_Details"
s = s & "                                   INNER JOIN dbo.Transactions"
s = s & "                                        ON  dbo.Transaction_Details.Transaction_ID = dbo.Transactions.Transaction_ID"
s = s & "                                   INNER JOIN dbo.TransactionTypes"
s = s & "                                        ON  dbo.Transactions.Transaction_Type = dbo.TransactionTypes.Transaction_Type"
s = s & "                            WHERE  (dbo.Transaction_Details.Item_ID = @itemid)"
s = s & "                                   AND (dbo.Transaction_Details.UnitID = @UnitID)"
s = s & "                                   AND (dbo.transactions.Transaction_Type = 21)"
s = s & "                        )"
s = s & "             ) AND @IsLastPrice = 1"
s = s & "         )"
        
    
s = s & "     Else"
s = s & "     SET @Value ="
s = s & " ("
s = s & "             SELECT UnitPurPrice"
s = s & "             From TblItemsUnits"
s = s & "             WHERE  ItemID         = @itemid"
s = s & "                    AND UnitID     = @UnitID"
s = s & "                    AND @IsLastPrice = 0"
s = s & "         )"
        
s = s & "     RETURN @Value"

s = s & " End"



    
