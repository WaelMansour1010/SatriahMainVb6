              sql = "DROP FUNCTION QryGetStudent" & Chr(13)
    Cn.Execute sql
    sql = " CREATE FUNCTION QryGetStudent()" & Chr(13)
    sql = sql & "RETURNS @xTable TABLE" & Chr(13)
    sql = sql & "(" & Chr(13)
    sql = sql & "StuID int," & Chr(13)
    sql = sql & "Name nvarchar(255)," & Chr(13)
    sql = sql & "NameE nvarchar(255)," & Chr(13)
    sql = sql & "FullCode nvarchar(100)," & Chr(13)
    sql = sql & "ContNoID int" & Chr(13)
    sql = sql & ")" & Chr(13)
    sql = sql & "AS" & Chr(13)
    sql = sql & "Begin" & Chr(13)
    sql = sql & "INSERT @xTable" & Chr(13)
    sql = sql & " SELECT     dbo.TblStuCandidacyDet.StuID, dbo.TblStudent.Name, dbo.TblStudent.NameE, dbo.TblStudent.FullCode, dbo.TblStuCandidacy.ContNoID" & Chr(13)
    sql = sql & "     FROM         dbo.TblStudent RIGHT OUTER JOIN" & Chr(13)
    sql = sql & "                  dbo.TblStuCandidacyDet ON dbo.TblStudent.ID = dbo.TblStuCandidacyDet.StuID RIGHT OUTER JOIN" & Chr(13)
    sql = sql & "                  dbo.TblStuCandidacy ON dbo.TblStuCandidacyDet.StudCandID = dbo.TblStuCandidacy.ID" & Chr(13)
    sql = sql & "   Where (dbo.TblStuCandidacyDet.AccptedID = 1)" & Chr(13)
    sql = sql & "Return" & Chr(13)
    sql = sql & " End" & Chr(13)
    db_createOrUpdateFuctionSQL "QryGetStudent", sql
    
