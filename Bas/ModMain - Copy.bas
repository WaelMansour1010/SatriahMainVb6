     sql = " Create FUNCTION Fn_GetPriceItem(@ItemID AS INT,@mValue AS MONEY)"
    sql = sql & " RETURNS Money As "
    
    sql = sql & " Begin"
    sql = sql & "  DECLARE @Price AS MONEY"
    sql = sql & " SET @Price = ("
    sql = sql & "        SELECT Top 1 IsNull(Price,0) FROM ItemsPriceIsPerv T WHERE ItemID = @ItemID"
    sql = sql & "        AND @mValue BETWEEN IsNull(FromPrice,0) and CASE WHEN IsNull(ToPrice,0) = 0 THEN 4123121654 ELSE IsNull(ToPrice,0) END )"
    sql = sql & "        RETURN @Price End"
