           sql = "    DROP FUNCTION QryItemsInventry3" & Chr(13)
    Cn.Execute sql

    sql = "CREATE FUNCTION [dbo].[QryItemsInventry3] (@fromdate datetime,@todate datetime,@StoreId AS INT=null,@ColorID AS INT=null,@ItemSize AS  NVARCHAR(255)=null ," & Chr(13)
    sql = sql & " @ClassId AS INT=null , @order_no  AS  NVARCHAR(255)  =null,@CusID as float=null)" & Chr(13)
    sql = sql & " RETURNS @XTable Table" & Chr(13)
    sql = sql & " (" & Chr(13)
    sql = sql & " Item_ID  Decimal (18,2)," & Chr(13)
    sql = sql & " ItemCode     nvarchar(255)  ," & Chr(13)
    sql = sql & " ItemName  nvarchar(255)     ," & Chr(13)
    sql = sql & " openingValue  Decimal (18,2)," & Chr(13)
    sql = sql & " inputvalue  Decimal (18,2)," & Chr(13)
    sql = sql & " outputValue Decimal(18, 2)" & Chr(13)
    sql = sql & " )" & Chr(13)
    sql = sql & " AS" & Chr(13)
    sql = sql & " Begin" & Chr(13)
    sql = sql & " INSERT  @XTable" & Chr(13)
    sql = sql & " Select      Item_ID, ItemCode, ItemName,  Sum(DEV_Value1) as openingValue,Sum(DEV_Value2) as inputvalue , Sum(DEV_Value3) as outputValue" & Chr(13)
    sql = sql & " From" & Chr(13)
    sql = sql & " (" & Chr(13)
    sql = sql & " SELECT" & Chr(13)
    sql = sql & " Item_ID,ItemCode, ItemName," & Chr(13)
    sql = sql & " DEV_Value1=Case" & Chr(13)
    sql = sql & " When  (dbo.TransactionTypes.StockEffect = 1)  and (dbo.Transactions.Transaction_Type=3)   Then  (Quantity * dbo.TransactionTypes.StockEffect)" & Chr(13)
    sql = sql & " Else 0" & Chr(13)
    sql = sql & " END," & Chr(13)
    sql = sql & " DEV_Value2=Case" & Chr(13)
    sql = sql & " When  (dbo.TransactionTypes.StockEffect = 1)  and (dbo.Transactions.Transaction_Type<>3)   Then  (Quantity * dbo.TransactionTypes.StockEffect)" & Chr(13)
    sql = sql & " Else 0" & Chr(13)
    sql = sql & " End" & Chr(13)
    sql = sql & "," & Chr(13)
    sql = sql & " DEV_Value3=Case" & Chr(13)
    sql = sql & " When    (dbo.TransactionTypes.StockEffect = -1)   Then ( Quantity * dbo.TransactionTypes.StockEffect)" & Chr(13)
    sql = sql & " Else 0" & Chr(13)
    sql = sql & " End" & Chr(13)

    sql = sql & "  FROM         dbo.Transaction_Details INNER JOIN dbo.Transactions ON dbo.Transaction_Details.Transaction_ID = dbo.Transactions.Transaction_ID" & Chr(13)
    sql = sql & " INNER JOIN  dbo.TransactionTypes ON dbo.Transactions.Transaction_Type = dbo.TransactionTypes.Transaction_Type" & Chr(13)
    sql = sql & " INNER JOIN    dbo.TblItems ON dbo.Transaction_Details.Item_ID = dbo.TblItems.ItemID" & Chr(13)
    sql = sql & " where dbo.Transactions.Transaction_Date>=@fromdate" & Chr(13)
    sql = sql & " and dbo.Transactions.Transaction_Date <=@todate" & Chr(13)
  
    sql = sql & " and  Storeid=isnull(@Storeid,Storeid)" & Chr(13)
    sql = sql & " and  ColorID=isnull(@ColorID,ColorID)" & Chr(13)
    sql = sql & " and  ItemSize=isnull(@ItemSize,ItemSize)" & Chr(13)
    sql = sql & " and  ClassId=isnull(@ClassId,ClassId)" & Chr(13)
    'sql = sql & " and  CusID=isnull(@CusID,CusID)" & Chr(13)
       
    '   sql = sql & " and  Transaction_Details.order_no= isnull(@order_no,Transaction_Details.order_no)" & Chr(13)
    sql = sql & " )XTable" & Chr(13)
    sql = sql & " group by Item_ID ,ItemCode, ItemName" & Chr(13)
    sql = sql & " Return " & Chr(13)
    sql = sql & " End" & Chr(13)
  
    db_createOrUpdateFuctionSQL "QryItemsInventry3", sql
