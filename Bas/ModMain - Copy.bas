    sql = "    DROP FUNCTION GetItemqtytodateNEW" & Chr(13)
    Cn.Execute sql

    sql = " CREATE FUNCTION GetItemqtytodateNEW( @Todate datetime ,@itemid as integer,@Storeid as float=null,@ColorID as float=null,@ItemSize  as float=null,@ClassId as float=null, @order_no as nvarchar(255)=null ,@CusID as float =null)" & Chr(13)
    sql = sql & " RETURNS Float" & Chr(13)
    sql = sql & " AS" & Chr(13)
    sql = sql & " Begin" & Chr(13)
    sql = sql & " RETURN ( SELECT     SUM(dbo.Transaction_Details.Quantity * dbo.TransactionTypes.StockEffect) as SumQty" & Chr(13)
    sql = sql & " FROM         dbo.Transaction_Details INNER JOIN dbo.Transactions ON dbo.Transaction_Details.Transaction_ID = dbo.Transactions.Transaction_ID" & Chr(13)
    sql = sql & " INNER JOIN  dbo.TransactionTypes ON dbo.Transactions.Transaction_Type = dbo.TransactionTypes.Transaction_Type" & Chr(13)
    sql = sql & " WHERE     (dbo.TransactionTypes.StockEffect <> 0) AND (dbo.Transaction_Details.Item_ID = @itemid )   AND (dbo.Transactions.Transaction_Date <= @Todate )  " & Chr(13)
    sql = sql & " and  Storeid=isnull(@Storeid,Storeid)" & Chr(13)
    sql = sql & " and  ColorID=isnull(@ColorID,ColorID)" & Chr(13)
    sql = sql & " and  ItemSize=isnull(@ItemSize,ItemSize)" & Chr(13)
    sql = sql & " and  ClassId=isnull(@ClassId,ClassId)" & Chr(13)
    '    sql = sql & " and  CusID=isnull(@CusID,CusID)" & Chr(13)
     
    '  sql = sql & " and  Transaction_Details.order_no= isnull(@order_no,Transaction_Details.order_no)" & Chr(13)
    sql = sql & " )" & Chr(13)
    sql = sql & " End" & Chr(13)
    db_createOrUpdateFuctionSQL "GetItemqtytodateNEW", sql
   
