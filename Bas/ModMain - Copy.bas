  sql = sql & "  TotalDiscount float," & Chr(13)
  sql = sql & "  Mokafea float," & Chr(13)
  sql = sql & "  Notes nvarchar(255)," & Chr(13)
  sql = sql & "  TotalAdvance Float" & Chr(13)
  sql = sql & " )" & Chr(13)
  sql = sql & " AS" & Chr(13)

  sql = sql & " Begin" & Chr(13)
  sql = sql & "  INSERT  @XTable" & Chr(13)
  sql = sql & "  SELECT     dbo.TblEmployee.Emp_ID, dbo.TblEmployee.Emp_Name, dbo.TblEmpAdvanceDetails.PartDate," & Chr(13)
  sql = sql & "  dbo.TblEmployee.Emp_Salary, '' as Dis_type,'I?? ???E ' as Type,0 as TotalDiscount,0 as Mokafea,'' as Notes," & Chr(13)
  sql = sql & "  dbo.TblEmpAdvanceDetails.PartValue as TotalAdvance" & Chr(13)
