          sql = "    DROP FUNCTION GetQtyIsue" & Chr(13)
    Cn.Execute sql
    
    
    sql = " CREATE FUNCTION GetQtyIsue(@NoteSerial1 as varchar(255),@Transaction_ID as integer ,@Item_ID as integer ,@ColorID as integer,@ClassId as integer,@itemsize as integer,@UnitID as integer )" & Chr(13)
    sql = sql & "      RETURNS Float" & Chr(13)
    sql = sql & "     AS" & Chr(13)
    sql = sql & "    Begin" & Chr(13)
    sql = sql & "    RETURN ( "
    sql = sql & "    SELECT   SUM(dbo.Transaction_Details.ShowQty * isnull( dbo.Transaction_Details.FLgOrderSal,1)) AS smQty" & Chr(13)
    sql = sql & "      FROM         dbo.Transaction_Details RIGHT OUTER JOIN" & Chr(13)
    sql = sql & "                        dbo.Transactions ON dbo.Transaction_Details.Transaction_ID = dbo.Transactions.Transaction_ID" & Chr(13)
    sql = sql & "      WHERE     (((dbo.Transactions.order_no = @NoteSerial1) AND (dbo.Transactions.Transaction_Type = 19)) OR" & Chr(13)
    sql = sql & "                    (   (dbo.Transactions.NoteSerial1 = @NoteSerial1) AND (dbo.Transactions.Transaction_Type = 6)))" & Chr(13)
    sql = sql & "     AND (dbo.Transaction_Details.Item_ID = @Item_ID) AND (dbo.Transaction_Details.UnitId = @UnitID) and(dbo.Transaction_Details.ColorID =@ColorID) and(dbo.Transaction_Details.ClassId = @ClassId)and(dbo.Transaction_Details.ItemSize = @itemsize)" & Chr(13)
    sql = sql & "  AND   Transaction_Details.Transaction_ID <>@Transaction_ID" & Chr(13)
    sql = sql & "  GROUP BY dbo.Transaction_Details.ColorID, dbo.Transaction_Details.ItemSize, dbo.Transaction_Details.ClassId, dbo.Transaction_Details.Item_ID," & Chr(13)
    sql = sql & "                     dbo.Transaction_Details.unitid" & Chr(13)
    sql = sql & "     )" & Chr(13)
    sql = sql & "    End" & Chr(13)
    db_createOrUpdateFuctionSQL "GetQtyIsue", sql



