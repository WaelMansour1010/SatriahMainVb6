Public Function updateExpenses_Oreder_qry()
    Dim New_View  As String
    New_View = " SELECT     dbo.notes_all.NoteID, dbo.notes_all.NoteDate, dbo.notes_all.NoteType, dbo.notes_all.NoteSerial, dbo.notes_all.Note_Value, dbo.notes_all.BankID, "
    New_View = New_View & "  dbo.notes_all.ChqueNum, dbo.notes_all.DueDate, dbo.notes_all.UserID, dbo.notes_all.Remark, dbo.notes_all.ExpensesID, dbo.notes_all.BoxID,"
    New_View = New_View & "  dbo.TblUsers.UserName, dbo.TblBoxesData.BoxName, dbo.BanksData.BankName, dbo.notes_all.too, dbo.Notes.Note_Value AS [Sub-value],"
    New_View = New_View & "  dbo.Notes.note_value_by_characters AS sub_note_value_by_char, dbo.Notes.Remark AS sub_remark, dbo.ExpensesType.Name AS Sub_expenses_name,"
    New_View = New_View & "  dbo.Notes.NoteType AS sub_notetype, dbo.notes_all.note_value_by_characters, dbo.notes_all.general_des, dbo.notes_all.NoteSerial1,"
    New_View = New_View & "  dbo.Notes.ExpensesRemark"
    New_View = New_View & "  FROM         dbo.ExpensesType RIGHT OUTER JOIN"
    New_View = New_View & "  dbo.Notes ON dbo.ExpensesType.ID = dbo.Notes.ExpensesID LEFT OUTER JOIN"
    New_View = New_View & "  dbo.TblBoxesData ON dbo.Notes.BoxID = dbo.TblBoxesData.BoxID FULL OUTER JOIN"
    New_View = New_View & "  dbo.notes_all ON dbo.Notes.notes_all = dbo.notes_all.NoteID FULL OUTER JOIN"
    New_View = New_View & "  dbo.BanksData ON dbo.Notes.BankID = dbo.BanksData.BankID FULL OUTER JOIN"
    New_View = New_View & "  dbo.TblUsers ON dbo.Notes.UserID = dbo.TblUsers.UserID"
    New_View = New_View & "   WHERE     (dbo.Notes.NoteType = 3) AND (NOT (dbo.ExpensesType.Name IS NULL))"
 
    db_createOrUpdateviewSQL "Expanses_Order", New_View

End Function

Public Function GardByUnits()
    Dim New_View  As String
    New_View = "  SELECT     dbo.Transaction_Details.ShowQty * dbo.TransactionTypes.StockEffect AS totalQty, "
    New_View = New_View & "  dbo.Transaction_Details.ShowQty * dbo.Transaction_Details.showPrice * dbo.TransactionTypes.StockEffect AS Totalvalue, dbo.Transaction_Details.Item_ID,"
    New_View = New_View & "   dbo.TblItems.ItemCode, dbo.TblItems.ItemName, dbo.TblItems.ItemNamee, dbo.Transaction_Details.UnitId, dbo.TblUnites.UnitName, dbo.TblUnites.UnitNamee,"
    New_View = New_View & "  dbo.Transactions.Transaction_Type, dbo.TblItemsColors.ColorName, dbo.TblItemsSizes.SizeName, dbo.TblItemsclasses.SizeId,"
    New_View = New_View & "  dbo.TblItemsclasses.SizeName AS classname, dbo.Transactions.Transaction_Date, dbo.Transactions.CusID, dbo.Transactions.StoreID, dbo.TblItems.GroupID,"
    New_View = New_View & "  openingBalances = CASE WHEN dbo.Transactions.Transaction_Type = 3 THEN dbo.Transaction_Details.ShowQty * dbo.TransactionTypes.StockEffect ELSE 0 END,"
    New_View = New_View & "  Inputqty = CASE WHEN dbo.Transactions.Transaction_Type <> 3 AND"
    New_View = New_View & "  StockEffect = 1 THEN dbo.Transaction_Details.ShowQty * dbo.TransactionTypes.StockEffect ELSE 0 END,"
    New_View = New_View & "  output = CASE WHEN dbo.Transactions.Transaction_Type <> 3 AND"
    New_View = New_View & "  StockEffect = - 1 THEN dbo.Transaction_Details.ShowQty * dbo.TransactionTypes.StockEffect ELSE 0 END"
    New_View = New_View & "  FROM         dbo.Transactions INNER JOIN"
    New_View = New_View & "  dbo.Transaction_Details ON dbo.Transactions.Transaction_ID = dbo.Transaction_Details.Transaction_ID INNER JOIN"
    New_View = New_View & "  dbo.TransactionTypes ON dbo.Transactions.Transaction_Type = dbo.TransactionTypes.Transaction_Type INNER JOIN"
    New_View = New_View & "  dbo.TblItems ON dbo.Transaction_Details.Item_ID = dbo.TblItems.ItemID LEFT OUTER JOIN"
    New_View = New_View & "  dbo.TblItemsclasses ON dbo.Transaction_Details.ClassId = dbo.TblItemsclasses.SizeId LEFT OUTER JOIN"
    New_View = New_View & "  dbo.TblItemsSizes ON dbo.Transaction_Details.ItemSize = dbo.TblItemsSizes.SizeId LEFT OUTER JOIN"
    New_View = New_View & "  dbo.TblItemsColors ON dbo.Transaction_Details.ColorID = dbo.TblItemsColors.ColorID LEFT OUTER JOIN"
    New_View = New_View & "  dbo.TblUnites ON dbo.Transaction_Details.UnitId = dbo.TblUnites.UnitID"
    New_View = New_View & "   Where (dbo.TransactionTypes.StockEffect <> 0)"
 
    db_createOrUpdateviewSQL "GardByUnits", New_View

End Function

Public Function AgingReports()
    Dim New_View  As String
    New_View = " SELECT     TOP 100 PERCENT dbo.Transactions.Transaction_ID, dbo.Transactions.Transaction_Type, dbo.TransactionTypes.TransactionTypeName, "
    New_View = New_View & " dbo.Transactions.Transaction_Date, dbo.TblCustemers.CusName,dbo.TblCustemers.CusNamee, dbo.Notes.NoteID, dbo.Notes.NoteType, dbo.Notes.Note_Value, dbo.Notes.DueDate,"
    New_View = New_View & " dbo.Transactions.Transaction_Serial, dbo.TblCustemers.CusID, dbo.Notes.NoteDate, dbo.TblNotesTypes.NotesTypeName, dbo.TblCustemers.Fullcode,"
    New_View = New_View & " dbo.Transactions.NoteSerial1"
    New_View = New_View & " FROM         dbo.TransactionTypes INNER JOIN"
    New_View = New_View & " dbo.TblCustemers INNER JOIN"
    New_View = New_View & " dbo.Transactions ON dbo.TblCustemers.CusID = dbo.Transactions.CusID INNER JOIN"
    New_View = New_View & " dbo.TblNotesTypes INNER JOIN"
    New_View = New_View & " dbo.Notes ON dbo.TblNotesTypes.NotesType = dbo.Notes.NoteType ON dbo.Transactions.Transaction_ID = dbo.Notes.Transaction_ID ON"
    New_View = New_View & " dbo.TransactionTypes.Transaction_Type = dbo.Transactions.Transaction_Type"
    New_View = New_View & " WHERE     (dbo.Notes.NoteType = 1) OR"
    New_View = New_View & " (dbo.Notes.NoteType = 2) OR"
    New_View = New_View & " (dbo.Notes.NoteType = 13)"
    New_View = New_View & " ORDER BY dbo.Transactions.Transaction_ID"
    db_createOrUpdateviewSQL "PaymentTime", New_View

End Function

Public Function Create_items_status_report(Optional runreport As Integer = 0, _
                                           Optional StrSQLDate As String)
    Dim New_View  As String
    '20 12 2011

    New_View = " SELECT DISTINCT order_no, MAX(OrderArrivalDate) AS OrderArrivalDateMax"
    New_View = New_View & "  From dbo.Transaction_Details "
 
    New_View = New_View & "   GROUP BY order_no"
    New_View = New_View & "   Having (Not (order_no Is Null)) And (Not (Max(OrderArrivalDate) Is Null))"
    db_createOrUpdateviewSQL "QRyOrdersData", New_View

    New_View = " SELECT     TOP 100 PERCENT SUM(dbo.TransactionTypes.StockEffect * dbo.Transaction_Details.Quantity * dbo.TblItems.SallingPrice) AS qty, "
    New_View = New_View & "   SUM(dbo.TransactionTypes.StockEffect * dbo.Transaction_Details.Quantity) AS Realqty, dbo.Transaction_Details.order_no"
    New_View = New_View & "   FROM         dbo.Transaction_Details INNER JOIN"

    New_View = New_View & "    dbo.TblItems ON dbo.Transaction_Details.Item_ID = dbo.TblItems.ItemID INNER JOIN"
    New_View = New_View & "    dbo.Transactions ON dbo.Transaction_Details.Transaction_ID = dbo.Transactions.Transaction_ID INNER JOIN"
    New_View = New_View & "    dbo.TransactionTypes ON dbo.Transactions.Transaction_Type = dbo.TransactionTypes.Transaction_Type "

    If runreport = 1 Then
        New_View = New_View & StrSQLDate
    End If

    New_View = New_View & "   GROUP BY dbo.Transaction_Details.order_no"

    db_createOrUpdateviewSQL "Items_Status1", New_View
 
