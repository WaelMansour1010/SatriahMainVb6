Private Function EnsureLogDir() As String
    On Error Resume Next
    Dim base As String, p As String
    base = App.path
    If right$(base, 1) = "\" Then
        p = base & "Logs"
    Else
        p = base & "\Logs"
    End If
    If LenB(Dir$(p, vbDirectory)) = 0 Then MkDir p  ' √‰‘∆ «·„Ã·œ
    EnsureLogDir = p
End Function

