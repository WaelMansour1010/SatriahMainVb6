            Msg = "нМИ ЕОКнЗС ЗбФеС..!!"
        Else
            Msg = "Must Select Month    ..!!"
        End If

        MsgBox Msg, vbOKOnly + vbInformation + vbMsgBoxRight + vbMsgBoxRtlReading, App.title
        CmbMonth.SetFocus
        SendKeys "{F4}"
        Exit Sub
    End If
 
    With Me.Grid

        If .Rows = .FixedRows Then
            If SystemOptions.UserInterface = ArabicInterface Then
                Msg = "нМИ ЕОКнЗС гжЩЭнд..!!"
            Else
                Msg = "Must Select Employess    ..!!"
            End If

            MsgBox Msg, vbOKOnly + vbInformation + vbMsgBoxRight + vbMsgBoxRtlReading, App.title
            Exit Sub
        End If
                         
    End With
 
    '-------------------------------------------------------------------------------------------
    Dim EmployeeSalary As Double
    Dim NoOfHours As Double
    Dim NoOfMinutes As Double
    Dim cProgress As ClsProgress
    Set cProgress = New ClsProgress
    cProgress.ProgressType = Waiting
    cProgress.StartProgress
    Dim NetHour As Double
    Dim SmuHourofShift As Double
    Dim SmuHourofVoca As Double
    Dim NoDayMonth As Integer
    Dim NoHourWork As Double
    DoEvents
 
    Dim i As Long
    'Check
  
    With Me.Grid

        For i = .FixedRows To .Rows - 1

            If .TextMatrix(i, .ColIndex("Emp_ID")) <> "" Then
                If Opt(0).value = True Then
                    If val(.TextMatrix(i, .ColIndex("Value"))) = 0 Then
                        If SystemOptions.UserInterface = ArabicInterface Then
                            Msg = "нМИ ЗПОЗб  ЮнгЙ Эн ЗбУШС СЮг ..!!" & i
                        Else
                            Msg = "Must Enter Value    ..!!" & i
                        End If

                        cProgress.FinishProgress
                        cProgress.StopProgess
                        Set cProgress = Nothing
                        MsgBox Msg, vbOKOnly + vbInformation + vbMsgBoxRight + vbMsgBoxRtlReading, App.title
                        '       CmbMonth.SetFocus
                        FocusGridOnCell i, .ColIndex("Value")
                        SendKeys "{F4}"
                        Exit Sub
                    End If
                        EmployeeSalary = GetEmployeeSalaryAccordingToComponent(val(.TextMatrix(i, .ColIndex("Emp_ID"))), LBLWhereSTR)
                                             .TextMatrix(i, .ColIndex("BasicSalary")) = EmployeeSalary
                                            ' MsgBox LBLWhereSTR
                ElseIf Opt(1).value = True Then
                 
                    EmployeeSalary = GetEmployeeSalaryAccordingToComponent(val(.TextMatrix(i, .ColIndex("Emp_ID"))), LBLWhereSTR)
     
                    'ЗнЗг
                     If Calcul30orRminder(val(DCComponent.BoundText)) = True Then
                       .TextMatrix(i, .ColIndex("HourRate")) = (EmployeeSalary / DaysInMonth(XPDtbTrans.value))
