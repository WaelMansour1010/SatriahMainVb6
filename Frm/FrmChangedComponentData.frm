Private Sub Coloring()
    Dim i As Integer
    Dim IntCounter As Integer

    With Grid

        For i = .FixedRows To .Rows - 1
        
            If i Mod 2 = 0 Then
                .Cell(flexcpBackColor, i, 1, i, 25) = &HFFFFC0
            Else
                .Cell(flexcpBackColor, i, 1, i, 25) = vbWhite
            End If

        Next i

    End With

    'line_no1 = IntCounter

End Sub

