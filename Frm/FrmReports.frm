            StrSQL = StrSQL + " AND (((XTable.StoreID) =" & Me.DCboStoreName.BoundText & "))"
            StrSQL = StrSQL + " ORDER BY xTable.ItemID,xTable.ItemSerial "
        ElseIf SystemOptions.SysDataBaseType = SQLServerDataBase Then
            StrSQL = "SELECT * FROM "
            StrSQL = StrSQL + "("
            StrSQL = StrSQL + "SELECT Sum( TransactionTypes.StockEffect * Transaction_Details.Quantity) AS Qty," & "TblItems.ItemID, TblItems.ItemCode,TblItems.GroupID, TblItems.ItemName,TblItems.HaveSerial, Transaction_Details.ItemSerial,"
