Private Sub Form_KeyDown(KeyCode As Integer, _
                         Shift As Integer)
    On Error GoTo ErrTrap

    If KeyCode = vbKeyF6 Then

        Select Case C1TabMain.CurrTab

            Case 0
                CmdPrint_Click

            Case 1
                CmdPrintBuy_Click

            Case 2
                XPBtn_M_Print_Click

            Case 3
                XPPrintTax_Click
        End Select

    End If

    If Shift = 2 Then
        C1TabMain.SetFocus

        If KeyCode = vbKeyTab Then
            If C1TabMain.CurrTab < C1TabMain.NumTabs - 1 Then
                C1TabMain.CurrTab = C1TabMain.CurrTab + 1
            Else
                C1TabMain.CurrTab = 0
            End If
        End If
    End If

    Exit Sub
ErrTrap:
End Sub

