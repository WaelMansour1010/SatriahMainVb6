    mCboOutStockType2 = False
    Dim mSelect As Boolean, mSelect2 As Boolean
    Dim GovernmentID As Long, sizeid As Long
    Dim mWhere As String
    Dim mWhere2 As String
    mWhere = " and  ( 1 = 0 Or  "
    mWhere2 = " and  ( 1 = 0 Or  "
    For i = 1 To FGCountry(0).rows - 1
        
        mSelect = FGCountry(0).ValueMatrix(i, FGCountry(0).ColIndex("SelectSanad"))
        GovernmentID = val(FGCountry(0).TextMatrix(i, FGCountry(0).ColIndex("GovernmentID")))
        mSelect2 = FGCountry(0).ValueMatrix(i, FGCountry(0).ColIndex("SelectSanad2"))
        sizeid = val(FGCountry(0).TextMatrix(i, FGCountry(0).ColIndex("SizeID")))
        If mSelect And GovernmentID <> 0 Then
            mCboOutStockType = True
            mWhere = mWhere & "  TblCustemers.GovernmentID =" & GovernmentID & " Or "

        End If
        If mSelect2 And sizeid <> 0 Then
            mCboOutStockType2 = True
        
            
            mWhere2 = mWhere2 & "  Groups.ClassId" & i & " =" & sizeid & " Or "

        End If
    Next
    mWhere = mWhere & "  1 = 0)"
    mWhere2 = mWhere2 & "  1 = 0)"
    
    If Not mCboOutStockType Then
        'GetCountrySql = ""
        FinalWhere = ""
    Else
        'GetCountrySql = mWhere
        FinalWhere = mWhere
    End If
    
    
      
    If Not mCboOutStockType2 Then
        'GetCountrySql = ""
       ' FinalWhere = ""
    Else
        'GetCountrySql = mWhere
        FinalWhere = FinalWhere & mWhere2
    End If
    GetCountrySql = FinalWhere
