Private Sub FGCountry_StartEdit(Index As Integer, ByVal Row As Long, ByVal Col As Long, Cancel As Boolean)
    Dim StrSQL As String
    Dim rs As New ADODB.Recordset
    Dim StrAccountType As String
    Dim StrComboList As String
    Dim StrAccountCode As String
    Dim StrAccountCode1 As String
    Dim Msg As String

If Index = 0 Then
    With FGCountry(Index)
        Select Case .ColKey(Col)
        Case "SizeName"
               
               StrSQL = "Select  SizeID,SizeName,SizeNamee FROM TblItemsclasses"
               Set rs = New ADODB.Recordset
                rs.Open StrSQL, Cn, adOpenStatic, adLockReadOnly, adCmdText
            If SystemOptions.UserInterface = ArabicInterface Then
                    StrComboList = .BuildComboList(rs, "SizeName", "SizeID")
                Else
                    StrComboList = .BuildComboList(rs, "SizeNamee", "SizeID")
                End If
       
                If StrComboList <> "" Then
                    StrComboList = "|" & StrComboList
                End If
                 .ComboList = StrComboList
                  StrAccountCode = .ComboData
        
            End Select
    End With
ElseIf Index >= 1 Then

    With FGCountry(Index)
        Select Case .ColKey(Col)
        Case "SizeName"
            If Row = 7 Or Row = 8 Then
                StrSQL = "Select  GroupID ID,GroupName Name,GroupNamee Namee FROM " & GetTableName(Row)
            ElseIf Row = 9 Then
                StrSQL = "Select  ColorID ID,colorname Name,colorname Namee FROM " & GetTableName(Row)
            ElseIf Row = 23 Then
                
               ' StrSQL = "Select  Id, cast(CLY AS NVARCHAR(10)) + '  ' + cast(clyt AS NVARCHAR(20)) NAME, cast(CLY AS NVARCHAR(10)) + '  ' + cast(clyt AS NVARCHAR(20)) NAMEe FROM " & GetTableName(Row)
                StrSQL = "Select  Id, clyt  NAME, clyt   NAMEe FROM " & GetTableName(Row)
            ElseIf Row = 22 Then
                 StrSQL = "Select  ID,SPHT NAME,SPHT Namee FROM " & GetTableName(Row)
                
            Else
                StrSQL = "Select  ID,Name,Namee FROM " & GetTableName(Row)
            End If
            Set rs = New ADODB.Recordset
            rs.Open StrSQL, Cn, adOpenStatic, adLockReadOnly, adCmdText
            If SystemOptions.UserInterface = ArabicInterface Then
                    StrComboList = .BuildComboList(rs, "Name", "ID")
                Else
                    StrComboList = .BuildComboList(rs, "Namee", "ID")
                End If
       
                If StrComboList <> "" Then
                    StrComboList = "|" & StrComboList
                End If
                 .ComboList = StrComboList
                  StrAccountCode = .ComboData
        
            End Select
    End With

End If
End Sub

