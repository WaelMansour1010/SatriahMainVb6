Private Function BuildSql_Buy()
    Dim StrSQL As String
    Dim Begin As Boolean
    On Error GoTo ErrTrap

    'item
    If XPChkBuy(2).value = Checked Then
        If Begin = True Then
            StrSQL = "select * From dbo.ReportBuyItems where ItemID=" & DCboItemBuy.BoundText
        Else
            StrSQL = "select * From dbo.ReportBuyItems where ItemID=" & DCboItemBuy.BoundText
            Begin = True
        End If

        If XPChkBuy(1).value = Checked Then
            If Begin = True Then
                StrSQL = StrSQL + " and CusID=" & DBCboClientNameBuy.BoundText
            Else
                StrSQL = StrSQL + " where CusID=" & DBCboClientNameBuy.BoundText
                Begin = True
            End If
        End If

        GoTo fin

    Else

        StrSQL = "select * From ReportBuyTime_Client"
    End If

    If Not IsNull(XPDtbBuyFrom.value) Then
        If Begin = True Then
            StrSQL = StrSQL + " and Transaction_Date >=" & SQLDate(XPDtbBuyFrom.value, True) & ""
        Else
            StrSQL = StrSQL + " where Transaction_Date >=" & SQLDate(XPDtbBuyFrom.value, True) & ""
            Begin = True
        End If
    End If

    If Not IsNull(XPDtpBuyTo.value) Then
        If Begin = True Then
            StrSQL = StrSQL + " and Transaction_Date <=" & SQLDate(XPDtpBuyTo.value, True) & ""
        Else
            StrSQL = StrSQL + " where Transaction_Date <=" & SQLDate(XPDtpBuyTo.value, True) & ""
            Begin = True
        End If
    End If

    If XPChkBuy(1).value = Checked Then
        If Begin = True Then
            StrSQL = StrSQL + " and CusID=" & DBCboClientNameBuy.BoundText
        Else
            StrSQL = StrSQL + " where CusID=" & DBCboClientNameBuy.BoundText
            Begin = True
        End If
    End If
    
    If Me.OptPayType(5).value = True Then
        If Begin = True Then
            StrSQL = StrSQL + " and PaymentType =0"
        Else
            StrSQL = StrSQL + " where PaymentType =0"
            Begin = True
        End If

    ElseIf Me.OptPayType(4).value = True Then

        If Begin = True Then
            StrSQL = StrSQL + " and PaymentType =1"
        Else
            StrSQL = StrSQL + " where PaymentType =1"
            Begin = True
        End If
    End If

fin:
    StrSQL = StrSQL + " Order BY Transaction_ID"
    BuildSql_Buy = StrSQL
    Exit Function
ErrTrap:
End Function

