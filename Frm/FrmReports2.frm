Function createlistString(mylist As ListBox, Optional ByRef Listitems As String)
    Dim i As Integer
    Dim str As String
    str = "0"
    Listitems = ""

    For i = 0 To mylist.ListCount - 1
        str = str & "," & mylist.ItemData(i)
        Listitems = Listitems & "," & mylist.List(i)

    Next i

    createlistString = str

End Function

