    If rs.RecordCount > 0 Then

        For i = 1 To rs.RecordCount
             
            If SystemOptions.UserInterface = ArabicInterface Then
                ListStoreall.AddItem IIf(IsNull(rs("StoreName").value), "", rs("StoreName").value)
