Function updatecostprice(StrSQL As String)
    Dim LngItemID As Long
    Dim LngUnitID As Long
    Dim RsDetails As New ADODB.Recordset
    Dim costPrice As Double
    Dim RowNum As Long
    RsDetails.Open StrSQL, Cn, adOpenStatic, adLockOptimistic, adCmdText

    If Not (RsDetails.EOF Or RsDetails.BOF) Then
    
        For RowNum = 1 To RsDetails.RecordCount
 
            LngItemID = IIf(IsNull(RsDetails("ItemID").value), "", RsDetails("ItemID").value)
            LngUnitID = IIf(IsNull(RsDetails("UnitID")), 1, (RsDetails("UnitID").value))
                  
            costPrice = ModItemCostPrice.GetCostItemPrice(LngItemID, 0, "", , SystemOptions.SysMainStockCostMethod, , , , , LngUnitID)
            Cn.Execute "Update tblitems set CostPrice=" & costPrice & " Where ItemID=" & LngItemID
                    
            '.TextMatrix(RowNum, FG.ColIndex("Price")) = IIf(IsNull(RsDetails("Price").value), "", RsDetails("Price").value)
            '        .TextMatrix(RowNum, FG.ColIndex("Valu")) = Val(.TextMatrix(RowNum, .ColIndex("Price"))) * Val(.TextMatrix(RowNum, .ColIndex("Count1")))
            RsDetails.MoveNext
        Next RowNum

    End If

End Function

