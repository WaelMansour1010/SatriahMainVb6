        End If
    End If

    If Not IsNull(FTXPDtpTo.value) Then
        If Begin = True Then
            StrSQL = StrSQL + " and dbo.Notes.NoteDate <=" & SQLDate(FTXPDtpTo.value, True) & ""
        Else
            StrSQL = StrSQL + " where dbo.Notes.NoteDate <=" & SQLDate(FTXPDtpTo.value, True) & ""
            Begin = True
        End If
    End If

    ' ÕœÌœ ‰Ê⁄ ÿ—ÌÞ…«·œð⁄
    'ÿ—ÌÞ… «·œð⁄ ‰ÞœÏ
    If Me.FTOptPayType(0).value = True Then
        If Begin = True Then
            StrSQL = StrSQL + " and dbo.Notes.NoteCashingType =0"
        Else
            StrSQL = StrSQL + " where dbo.Notes.NoteCashingType =0"
            Begin = True
        End If

        'ÿ—ÌÞ… «·œð⁄ ‘Ìþ
    ElseIf Me.FTOptPayType(1).value = True Then

        If Begin = True Then
            StrSQL = StrSQL + " and dbo.Notes.NoteCashingType =1"
        Else
            StrSQL = StrSQL + " where dbo.Notes.NoteCashingType =1"
            Begin = True
        End If
 
        'ÿ—ÌÞ… «·œð⁄ ÕÊ«·…
    ElseIf Me.FTOptPayType(2).value = True Then

        If Begin = True Then
            StrSQL = StrSQL + " and dbo.Notes.NoteCashingType =2"
