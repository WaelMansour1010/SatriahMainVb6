Private Function GetFieldValue(ByVal mFieldName As String, ByVal mFieldValue As String, ByVal mDataType As Long, ByVal mFieldReturn As Variant) As Variant
    Dim s As String, i As Long, m As String, m2 As String
    Dim mRet() As String
    ReDim Preserve mRet(UBound(mFieldReturn)) As String
    Dim rsDummy As New ADODB.Recordset
    'code,fullcode,parent_account,*
    m = ""
    For i = 0 To UBound(mFieldReturn)
        m2 = mFieldReturn(i) & " as Ret" & i
        If i < UBound(mFieldReturn) Then
            m = m & m2 & ","
        Else
            m = m & m2
        End If
    Next
    If mDataType = 0 Then
        s = "SELECT " & m & "   FROM TblCustemers AS tc WHERE Type = 1 and " & mFieldName & "  =  " & val(mFieldValue)
    Else
        s = "SELECT " & m & "   FROM TblCustemers AS tc WHERE  Type = 1 and " & mFieldName & "  =  '" & Trim(mFieldValue) & "'"
    End If

    rsDummy.Open s, Cn, adOpenStatic, adLockReadOnly, adCmdText
    For i = 0 To UBound(mFieldReturn)
        If Not rsDummy.EOF Then
            mRet(i) = (rsDummy.Fields(i) & "")
        Else
            mRet(i) = ""
        End If
    Next
    
        
   
    GetFieldValue = mRet()
End Function

