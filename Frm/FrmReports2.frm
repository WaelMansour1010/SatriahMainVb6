        Else
            StrSQL = StrSQL + " where dbo.Notes.NoteCashingType =5"
            Begin = True
        End If
    End If

    BuildSql3 = StrSQL
    Exit Function
 
End Function

Private Function BuildSql2() As String
    Dim StrSQL As String
    Dim Begin As Boolean
    'On Error GoTo ErrTrap

    StrSQL = "SELECT     TOP 100 PERCENT  dbo.Transactions.DepartementID, dbo.Transactions.BranchId, dbo.TblBranchesData.branch_name, dbo.TblBranchesData.branch_namee, dbo.TblBranchesData.ActivityTypeId, "
    StrSQL = StrSQL & "  dbo.tblActivitesType.Name AS ActivityName, dbo.tblActivitesType.namee AS ActivityNameE, dbo.Transactions.Transaction_Date, dbo.Transactions.Transaction_Type,"
    StrSQL = StrSQL & "  dbo.Transactions.PaymentType, dbo.Transactions.Trans_Discount, dbo.Transactions.Trans_DiscountType, dbo.Transactions.CusID, dbo.TblCustemers.CusName,"
    StrSQL = StrSQL & "    dbo.TblCustemers.Fullcode ,dbo.TblCustemers.CusNamee, dbo.Transactions.StoreID, dbo.TblStore.StoreName, dbo.TblStore.StoreNamee, dbo.Transactions.Emp_ID, dbo.TblEmployee.Emp_Name,"
    StrSQL = StrSQL & "  dbo.TblEmployee.Emp_Namee, dbo.Transactions.CashCustomerName, isnull(dbo.Transactions.Currency_id,1), dbo.currency.code AS CurencyCode,"
    StrSQL = StrSQL & "  dbo.Transactions.Currency_rate, dbo.Transactions.NoteSerial1, dbo.Transactions.NoteSerial, dbo.Transactions.remark, dbo.Transactions.Doctype,"
    StrSQL = StrSQL & "  dbo.Transactions.Transaction_ID, QryTransactionsTotal.TransSum, dbo.TblDoCumentsTypes.name AS DocTypeName,"
    StrSQL = StrSQL & "  dbo.TblDoCumentsTypes.namee AS DocTypeNamee, dbo.TransactionTypes.TransactionTypeName, dbo.TransactionTypes.TransactionEnglishName,"
    StrSQL = StrSQL & "  QryTransactionsTotal.TransNet,TransProfit , dbo.Transactions.DueDate"
    StrSQL = StrSQL & "  FROM         dbo.TblStore RIGHT OUTER JOIN"
    StrSQL = StrSQL & "  dbo.tblActivitesType RIGHT OUTER JOIN"
