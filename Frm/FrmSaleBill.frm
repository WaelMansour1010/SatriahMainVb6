Sub AddRowFg2(l As Integer)
Dim i As Integer
Dim k As Integer
Dim StoreName As String
Dim item_cost As Variant
Dim ItemName As String
Dim FllCode As String
If SystemOptions.UserInterface = ArabicInterface Then
getStorenames val(FG.TextMatrix(l, FG.ColIndex("StoreID2"))), StoreName
GetItemData val(FG.TextMatrix(l, FG.ColIndex("Code"))), FllCode, ItemName
Else
getStorenames val(FG.TextMatrix(l, FG.ColIndex("StoreID2"))), , StoreName
GetItemData val(FG.TextMatrix(l, FG.ColIndex("Code"))), FllCode, ItemName
End If

With FG1
k = .rows
.rows = .rows + 1
        For i = k To .rows - 1
            .TextMatrix(i, .ColIndex("MianItemID")) = val(FG.TextMatrix(l, FG.ColIndex("Code")))
            .TextMatrix(i, .ColIndex("MainName")) = ItemName
            .TextMatrix(i, .ColIndex("Count")) = val(FG.TextMatrix(l, FG.ColIndex("Count")))
            .TextMatrix(i, .ColIndex("StoreName")) = StoreName
            .TextMatrix(i, .ColIndex("StoreID")) = val(FG.TextMatrix(l, FG.ColIndex("StoreID2")))
             item_cost = ModItemCostPrice.GetCostItemPrice(val(FG.TextMatrix(l, FG.ColIndex("Code"))), 0, , , SystemOptions.SysMainStockCostMethod, , , , , val(FG.TextMatrix(l, FG.ColIndex("UnitId"))))
            .TextMatrix(i, .ColIndex("ItemID")) = val(FG.TextMatrix(l, FG.ColIndex("Code")))
            .TextMatrix(i, .ColIndex("Code")) = FllCode
            .TextMatrix(i, .ColIndex("Name")) = ItemName
            .TextMatrix(i, .ColIndex("UnitName")) = FG.TextMatrix(l, FG.ColIndex("UnitId"))
            .TextMatrix(i, .ColIndex("UnitId")) = GetItemUnitsId(.TextMatrix(i, .ColIndex("UnitName")))
            .TextMatrix(i, .ColIndex("QtyMix")) = 1
            If val(.TextMatrix(i, .ColIndex("QtyMix"))) <> 0 Then
            .TextMatrix(i, .ColIndex("Qty")) = val(.TextMatrix(i, .ColIndex("Count"))) / val(.TextMatrix(i, .ColIndex("QtyMix")))
            End If
            .TextMatrix(i, .ColIndex("Cost")) = item_cost
            .TextMatrix(i, .ColIndex("Valu")) = val(.TextMatrix(i, .ColIndex("Cost"))) * val(.TextMatrix(i, .ColIndex("Qty")))
            
        Next i
 End With
    
End Sub
Sub AddRowFg(l As Integer)
  Dim StrSQL As String
    Dim rs2 As ADODB.Recordset
    Dim i As Integer
Dim k As Integer
Dim StoreName As String
Dim ItemName As String

If SystemOptions.UserInterface = ArabicInterface Then
getStorenames val(FG.TextMatrix(l, FG.ColIndex("StoreID2"))), StoreName
GetItemData val(FG.TextMatrix(l, FG.ColIndex("Code"))), , ItemName
Else
getStorenames val(FG.TextMatrix(l, FG.ColIndex("StoreID2"))), , StoreName
GetItemData val(FG.TextMatrix(l, FG.ColIndex("Code"))), , ItemName
End If
  
    StrSQL = " SELECT     dbo.TblDefComItem.ID, dbo.TblDefComItem.MaxNo,TblDefComItemData.Cost,  dbo.TblDefComItemData.ItemID, dbo.TblItems.ItemName, dbo.TblItems.Fullcode, dbo.TblItems.ItemNamee, "
    StrSQL = StrSQL + "                  dbo.TblDefComItemData.UnitID , dbo.TblUnites.UnitName, dbo.TblUnites.UnitNamee, dbo.TblDefComItemData.Qty, dbo.TblDefComItemData.cost ,dbo.TblDefComItemData.Qty Qty1,dbo.TblDefComItem.StoreID2"
    StrSQL = StrSQL + " FROM         dbo.TblUnites RIGHT OUTER JOIN"
    StrSQL = StrSQL + "                  dbo.TblDefComItemData ON dbo.TblUnites.UnitID = dbo.TblDefComItemData.UnitID LEFT OUTER JOIN"
    StrSQL = StrSQL + "                  dbo.TblItems ON dbo.TblDefComItemData.ItemID = dbo.TblItems.ItemID RIGHT OUTER JOIN"
    StrSQL = StrSQL + "                  dbo.TblDefComItem ON dbo.TblDefComItemData.IDDefCIT = dbo.TblDefComItem.ID"
    
    
    
StrSQL = " SELECT TblDefComItem.ID,"
StrSQL = StrSQL + "                         TblDefComItem.MaxNo,"
       
    StrSQL = StrSQL + "                         ISNULL(TblDefComItemDet.ItemID, TblDefComItemData.ItemID) AS ItemID,"
    StrSQL = StrSQL + "                         ISNULL( TblItems.Fullcode, TblItems_1.Fullcode) AS Fullcode,"
    StrSQL = StrSQL + "                         TblItems_1.Fullcode,"
    StrSQL = StrSQL + "                         TblDefComItemData.UnitID,"
    StrSQL = StrSQL + "                         TblDefComItemDet.FlgX,"
    StrSQL = StrSQL + "                         ISNULL(TblDefComItemDet.cost, TblDefComItemData.cost) AS Cost,"
    StrSQL = StrSQL + "                         ISNULL(TblDefComItemDet.Qty, TblDefComItemData.Qty) AS Qty,"
    StrSQL = StrSQL + "                         TblDefComItemData.Qty     AS Qty1,"
    StrSQL = StrSQL + "                         TblDefComItem.StoreID2,"
    StrSQL = StrSQL + "                         ISNULL(TblItems.ItemName, TblItems_1.ItemName) AS ItemName,"
    StrSQL = StrSQL + "                         ISNULL(TblUnites.UnitName, TblUnites_1.UnitName) As UnitName,"
    StrSQL = StrSQL + "                         ISNULL(TblItems.ItemNamee, TblItems_1.ItemNamee) AS ItemNamee,"
    StrSQL = StrSQL + "                         ISNULL(TblUnites.UnitNamee, TblUnites_1.UnitNamee) As UnitNamee"
       
       
    StrSQL = StrSQL + "                  FROM   TblUnites                 AS TblUnites_1"
    StrSQL = StrSQL + "                         RIGHT OUTER JOIN TblDefComItemData"
    StrSQL = StrSQL + "                              ON  TblUnites_1.UnitID = TblDefComItemData.UnitID"
    StrSQL = StrSQL + "                         LEFT OUTER JOIN TblDefComItemDet"
    StrSQL = StrSQL + "                         LEFT OUTER JOIN TblUnites"
    StrSQL = StrSQL + "                              ON  TblDefComItemDet.UnitID = TblUnites.UnitID"
    StrSQL = StrSQL + "                         LEFT OUTER JOIN TblItems"
    StrSQL = StrSQL + "                              ON  TblDefComItemDet.ItemID = TblItems.ItemID"
    StrSQL = StrSQL + "                              ON  TblDefComItemData.LineID = TblDefComItemDet.LineID"
    StrSQL = StrSQL + "                              AND TblDefComItemData.IDDefCIT = TblDefComItemDet.IDDefCIT"
