Function GetNumbers(value) As String
Dim Index As Long
Dim Digit
Dim Final
Dim count As Long

  count = 1
  GetNumbers = Space(Len(value))
  For Index = 1 To Len(value)
    Digit = CHR(Asc(mId(value, Index, 1)))
    If Digit Like "[0-9]" Then
      Mid(GetNumbers, count, 1) = Digit
      count = count + 1
    End If
  Next

  GetNumbers = left(GetNumbers, count - 1)
End Function

