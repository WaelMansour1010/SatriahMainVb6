Private Function GetCostFromMix(ByVal mRow As Long) As Double
    'If Trim(TxtMaxNo2) = "" Then Exit Function
    Dim mItemNo As Long
    Dim mUnitId As Integer
    Dim TxtMaxNo2 As String
    mItemNo = val(FG.TextMatrix(mRow, FG.ColIndex("Code")))
    mUnitId = val(FG.cell(flexcpData, mRow, FG.ColIndex("UnitID")))
    TxtMaxNo2 = Trim(FG.TextMatrix(mRow, FG.ColIndex("MixNo")))
    Dim s As String
    Dim rsDummy As New ADODB.Recordset
    If chkIsMaxFromInvoice Then
        s = " SELECT Sum(TblDefComItemData.cost) Cost FROM TblDefComItemData"
        s = s & " Inner Join"
        s = s & " TblDefComItem"
        s = s & " ON TblDefComItem.ID = TblDefComItemData.IDDefCIT"
        s = s & " Where MaxNo = N'" & Trim(TxtMaxNo2) & "'"
    Else
            s = " SELECT TblDefComItemData.cost Cost FROM TblDefComItemData"
        s = s & " Inner Join"
        s = s & " TblDefComItem"
        s = s & " ON TblDefComItem.ID = TblDefComItemData.IDDefCIT"
        s = s & " Where MaxNo = N'" & Trim(TxtMaxNo2) & "'"
        s = s & " AND TblDefComItemData.ItemID = " & mItemNo
        s = s & " AND TblDefComItemData.UnitID =" & mUnitId
    End If

    rsDummy.Open s, Cn, adOpenStatic, adLockReadOnly
    If Not rsDummy.EOF Then
       ' GetCostFromMix = val(rsDummy!cost & "")
        If val(rsDummy!cost & "") <> 0 Then
            GetCostFromMix = val(rsDummy!cost & "")
        End If

        
    End If
    


End Function
