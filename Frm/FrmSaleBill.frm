Function GeteBillBuy(Optional Transaction_ID As Double = 0, Optional ByVal NCashingType As Integer = 0) As Double
Dim sql As String
Dim Rs8 As ADODB.Recordset
Set Rs8 = New ADODB.Recordset
sql = " SELECT   SUM(PayedValue) AS Smatiobn"
