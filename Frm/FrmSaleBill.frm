sql = sql & " Where (Transaction_ID = " & Transaction_ID & ")"
If NCashingType <> 0 Then
    sql = sql & " and  (NCashingType= " & NCashingType & ")"
End If
sql = sql & " GROUP BY Transaction_ID"
