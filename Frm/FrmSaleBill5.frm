Function GetSumShowQty2(Optional ItemID As Double) As Double
Dim sql As String
Dim rs2 As ADODB.Recordset
Set rs2 = New ADODB.Recordset
sql = " SELECT     TOP 100 PERCENT SUM(dbo.Transaction_Details.ShowQty) AS SumShowQty"
sql = sql & " FROM         dbo.Transaction_Details RIGHT OUTER JOIN"
sql = sql & "                      dbo.Transactions ON dbo.Transaction_Details.Transaction_ID = dbo.Transactions.Transaction_ID"
sql = sql & " where      (dbo.Transaction_Details.Item_ID = " & ItemID & ") AND (dbo.Transactions.order_no = '" & TXTOrDer_no.text & "') AND (dbo.Transactions.Transaction_Type = 21) AND"
sql = sql & "                      (dbo.Transaction_Details.Transaction_ID = " & val(XPTxtBillID.text) & " and dbo.Transactions.CBoBasedON= 5)"
rs2.Open sql, Cn, adOpenStatic, adLockOptimistic, adCmdText
If rs2.RecordCount > 0 Then
GetSumShowQty2 = IIf(IsNull(rs2("SumShowQty").value), 0, rs2("SumShowQty").value)
Else
GetSumShowQty2 = 0
End If
End Function
