Sub UpdateBooking(Optional FlgDel As Integer = 0)
Dim RowNum As Integer
Dim sql As String
Dim StrSQL As String
Dim QtyDat As Double
Dim rs2 As ADODB.Recordset
Set rs2 = New ADODB.Recordset
Dim Transaction_ID As Double
StrSQL = "Select * from transactions where  Transaction_Type=39 and NoteSerial1='" & TXTOrDer_no.text & "'"
rs2.Open StrSQL, Cn, adOpenStatic, adLockOptimistic, adCmdText
If rs2.RecordCount <= 0 Then
Exit Sub
Else
Transaction_ID = IIf(IsNull(rs2("Transaction_ID").value), 0, rs2("Transaction_ID").value)
End If
With FG
   For RowNum = 1 To .Rows - 1
   If .TextMatrix(RowNum, .ColIndex("Code")) <> "" Then
   QtyDat = 0
   If FlgDel = 0 Then
   QtyDat = GetSumShowQty(val(.TextMatrix(RowNum, .ColIndex("Code")))) + val(.TextMatrix(RowNum, .ColIndex("Count")))
    sql = "Update Transaction_Details set ShowQty= Quantity- " & QtyDat & " where Transaction_ID=" & Transaction_ID & " and Item_ID=" & val(.TextMatrix(RowNum, .ColIndex("Code"))) & ""
   Cn.Execute sql
   Else
   QtyDat = GetSumShowQty2(val(.TextMatrix(RowNum, .ColIndex("Code"))))
    sql = "Update Transaction_Details set ShowQty= ShowQty +" & QtyDat & " where Transaction_ID=" & Transaction_ID & " and Item_ID=" & val(.TextMatrix(RowNum, .ColIndex("Code"))) & ""
   Cn.Execute sql
   End If
  
   End If
  Next RowNum
End With
End Sub
