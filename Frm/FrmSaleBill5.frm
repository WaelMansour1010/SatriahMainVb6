            FG.TextMatrix(Num, FG.ColIndex("UnitID")) = IIf(IsNull(RsDetails("UnitName")), "", (RsDetails("UnitName").value))
        
         Dim Price As Double
            
                            
                          Price = GetItemPrice(val(FG.TextMatrix(Num, FG.ColIndex("Code"))), 1, val(FG.Cell(flexcpData, Num, FG.ColIndex("UnitID"))))
 If 1 = 1 Then
