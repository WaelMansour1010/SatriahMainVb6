Sub GetOrderMaint()
If 1 = 1 Then
Dim sql As String
Dim rs2 As ADODB.Recordset
Set rs2 = New ADODB.Recordset
sql = " SELECT     EquepID"
sql = sql & " From dbo.TblOrderMaint"
sql = sql & "  where ID =" & val(TXTOrDer_no.text) & ""
rs2.Open sql, Cn, adOpenStatic, adLockOptimistic, adCmdText
If rs2.RecordCount > 0 Then
DCEquipments.BoundText = IIf(IsNull(rs2("EquepID").value), "", rs2("EquepID").value)
Else
DCEquipments.BoundText = 0
End If
End If
End Sub


Sub GetOrderMaintdet()
If 1 = 1 Then
Dim sql As String
Dim rs2 As ADODB.Recordset
Set rs2 = New ADODB.Recordset
sql = " SELECT     PartID"
sql = sql & " From dbo.tblordermaintenancetypes"
sql = sql & "  where ORderID =" & val(TXTOrDer_no.text) & " and TypeTrans=2"
rs2.Open sql, Cn, adOpenStatic, adLockOptimistic, adCmdText
