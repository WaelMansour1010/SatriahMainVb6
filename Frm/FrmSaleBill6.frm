Function CheckBillType() As Integer
    'تفوم بتخديد هل القاتورة اصناف ام خدمات ام مجمع اصناق وخدمات
    Dim DblTempItemsGoodType As Double
    Dim DblTempItemsServiceType As Double
    Dim gooditemCount As Double
Dim ServiceitemCount As Double
gooditemCount = 0
ServiceitemCount = 0

    DblTempItemsGoodType = NewGrid.GetItemsTotal(ItemsGoodType, gooditemCount)
    DblTempItemsServiceType = NewGrid.GetItemsTotal(ItemsServiceType, ServiceitemCount)

 
