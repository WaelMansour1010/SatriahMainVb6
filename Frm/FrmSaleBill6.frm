Sub UpdateBooking(Optional FlgDel As Integer = 0)
Dim RowNum As Integer
Dim sql As String
Dim StrSQL As String
Dim QtyDat As Double
Dim rs2 As ADODB.Recordset
Set rs2 = New ADODB.Recordset
Dim Transaction_ID As Double
StrSQL = "Select * from transactions where  Transaction_Type=39 and NoteSerial1='" & TXTOrDer_no.text & "'"
rs2.Open StrSQL, Cn, adOpenStatic, adLockOptimistic, adCmdText
If rs2.RecordCount <= 0 Then
Exit Sub
Else
Transaction_ID = IIf(IsNull(rs2("Transaction_ID").value), 0, rs2("Transaction_ID").value)
End If
With FG
   For RowNum = 1 To .rows - 1
   If .TextMatrix(RowNum, .ColIndex("Code")) <> "" Then
   QtyDat = 0
   If FlgDel = 0 Then
   QtyDat = GetSumShowQty(val(.TextMatrix(RowNum, .ColIndex("Code")))) + val(.TextMatrix(RowNum, .ColIndex("Count")))
    sql = "Update Transaction_Details set ShowQty= Quantity- " & QtyDat & " where Transaction_ID=" & Transaction_ID & " and Item_ID=" & val(.TextMatrix(RowNum, .ColIndex("Code"))) & ""
   Cn.Execute sql
   Else
   QtyDat = GetSumShowQty2(val(.TextMatrix(RowNum, .ColIndex("Code"))))
    sql = "Update Transaction_Details set ShowQty= ShowQty +" & QtyDat & " where Transaction_ID=" & Transaction_ID & " and Item_ID=" & val(.TextMatrix(RowNum, .ColIndex("Code"))) & ""
   Cn.Execute sql
   End If
  
   End If
  Next RowNum
End With
End Sub
Function CheckQtyBooking() As Boolean
Dim RowNum As Integer
Dim StrSQL As String
Dim rs2 As ADODB.Recordset
Set rs2 = New ADODB.Recordset
Dim Transaction_ID As Double
CheckQtyBooking = True
StrSQL = " Select * from transactions where  Transaction_Type=39 and NoteSerial1='" & TXTOrDer_no.text & "'"
rs2.Open StrSQL, Cn, adOpenStatic, adLockOptimistic, adCmdText
If rs2.RecordCount <= 0 Then
Exit Function
Else
Transaction_ID = IIf(IsNull(rs2("Transaction_ID").value), 0, rs2("Transaction_ID").value)
End If
With FG
   For RowNum = 1 To .rows - 1
   If .TextMatrix(RowNum, .ColIndex("Code")) <> "" Then
   If GetCurrQty(Transaction_ID, val(.TextMatrix(RowNum, .ColIndex("Code")))) < val(.TextMatrix(RowNum, .ColIndex("Count"))) Then
   If SystemOptions.UserInterface = ArabicInterface Then
   MsgBox "لايمكن الحفظ الكمية اكبر من الكمية المحجوزة في السطر " & RowNum
   Else
    MsgBox "Can not save quantity larger than reserved quantity in line " & RowNum
   End If
   CheckQtyBooking = False
   Exit Function
   End If
   End If
  Next RowNum
End With
End Function
Function GetCurrQty(Optional Transaction_ID As Double, Optional Item_ID As Double) As Double
Dim StrSQL As String
Dim rs2 As ADODB.Recordset
StrSQL = " SELECT     Transaction_ID, ShowQty"
StrSQL = StrSQL & " From dbo.Transaction_Details where Transaction_ID =" & Transaction_ID & " and Item_ID=" & Item_ID & ""
Set rs2 = New ADODB.Recordset
rs2.Open StrSQL, Cn, adOpenStatic, adLockOptimistic, adCmdText
If rs2.RecordCount > 0 Then
GetCurrQty = IIf(IsNull(rs2("ShowQty").value), 0, rs2("ShowQty").value)
Else
GetCurrQty = 0
End If
End Function
Function GetSumShowQty2(Optional ItemID As Double) As Double
Dim sql As String
Dim rs2 As ADODB.Recordset
Set rs2 = New ADODB.Recordset
sql = " SELECT     TOP 100 PERCENT SUM(dbo.Transaction_Details.ShowQty) AS SumShowQty"
sql = sql & " FROM         dbo.Transaction_Details RIGHT OUTER JOIN"
sql = sql & "                      dbo.Transactions ON dbo.Transaction_Details.Transaction_ID = dbo.Transactions.Transaction_ID"
sql = sql & " where      (dbo.Transaction_Details.Item_ID = " & ItemID & ") AND (dbo.Transactions.order_no = '" & TXTOrDer_no.text & "') AND (dbo.Transactions.Transaction_Type = 21) AND"
sql = sql & "                      (dbo.Transaction_Details.Transaction_ID = " & val(XPTxtBillID.text) & " and dbo.Transactions.CBoBasedON= 5)"
rs2.Open sql, Cn, adOpenStatic, adLockOptimistic, adCmdText
If rs2.RecordCount > 0 Then
GetSumShowQty2 = IIf(IsNull(rs2("SumShowQty").value), 0, rs2("SumShowQty").value)
Else
GetSumShowQty2 = 0
End If
End Function
Function GetSumShowQty(Optional ItemID As Double) As Double
Dim sql As String
Dim rs2 As ADODB.Recordset
Set rs2 = New ADODB.Recordset
sql = " SELECT     TOP 100 PERCENT SUM(dbo.Transaction_Details.ShowQty) AS SumShowQty"
sql = sql & " FROM         dbo.Transaction_Details RIGHT OUTER JOIN"
sql = sql & "                      dbo.Transactions ON dbo.Transaction_Details.Transaction_ID = dbo.Transactions.Transaction_ID"
sql = sql & " where      (dbo.Transaction_Details.Item_ID = " & ItemID & ") AND (dbo.Transactions.order_no = '" & TXTOrDer_no.text & "') AND (dbo.Transactions.Transaction_Type = 21) AND"
sql = sql & "                      (dbo.Transaction_Details.Transaction_ID <> " & val(XPTxtBillID.text) & " and dbo.Transactions.CBoBasedON= 5)"
rs2.Open sql, Cn, adOpenStatic, adLockOptimistic, adCmdText
If rs2.RecordCount > 0 Then
GetSumShowQty = IIf(IsNull(rs2("SumShowQty").value), 0, rs2("SumShowQty").value)
Else
GetSumShowQty = 0
End If
End Function
