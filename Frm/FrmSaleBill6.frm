                        GoTo ErrTrap
         
                    End If
                End If

                StrTempAccountCode = Account_Code_dynamic 'تكلفة المبيعات
            
                If SystemOptions.UserInterface = ArabicInterface Then
                    StrTempDes = "سند    اضافه رقم " & TxtNoteSerial1V & "بناء على مردودات مبيعات برقم " & Me.TxtNoteSerial1.text
                Else
                    StrTempDes = "Issue Voucher No. " & TxtNoteSerial1V
                End If
            
                LngDevNO = LngDevNO + 1

                If ModAccounts.AddNewDev(LngDevID, LngDevNO, StrTempAccountCode, TOTAL_COST, 1, StrTempDes, general_noteid, , , , Me.XPDtbBill.value, Me.DCboUserName.BoundText, Transaction_ID, , , , , , , , , , , , , , , , , val(Me.dcBranch.BoundText)) = False Then
                    GoTo ErrTrap
                End If
         
            ElseIf detect_inventory_work_type = 3 Then

                With FG

                    For i = 1 To FG.rows - 1

                        If FG.TextMatrix(i, FG.ColIndex("Code")) <> "" Then
    
                            groupAccount = get_item_group_account_in_branch(FG.TextMatrix(i, FG.ColIndex("Code")), val(my_branch), 1)

                            '  groupAccount = get_item_group_account_inventory(FG.TextMatrix(I, FG.ColIndex("Code")), DCboStoreName.BoundText, 4)
                            If groupAccount = "Error" Then
                                If SystemOptions.UserInterface = ArabicInterface Then
                                    MsgBox "الصنف في السطر رقم" & i & " غير محدد رقم حساب   تكلفة المبيعات   للمخزن المحدد   لمجموعتة"
                                Else
                                    MsgBox "Item in line no " & i & "Group Name Account Not Defined"
                                End If

                                GoTo ErrTrap
                            End If

                            line_value = ModItemCostPrice.GetCostItemPrice(FG.TextMatrix(i, FG.ColIndex("Code")), 1, , , SystemOptions.SysMainStockCostMethod, , , XPDtbBill.value) * FG.TextMatrix(i, FG.ColIndex("Count"))
    
                            If SystemOptions.UserInterface = ArabicInterface Then
                                StrTempDes = "سند    اضافه رقم " & TxtNoteSerial1V & "بناء على مردودات مبيعات برقم " & Me.TxtNoteSerial1.text
                            Else
                                StrTempDes = "Issue Voucher No. " & TxtNoteSerial1V
                            End If
            
                            LngDevNO = LngDevNO + 1

                            If ModAccounts.AddNewDev(LngDevID, LngDevNO, groupAccount, line_value, 1, StrTempDes, general_noteid, , , , Me.XPDtbBill.value, Me.DCboUserName.BoundText, Transaction_ID, , , , , , , , , , , , , , , , , val(Me.dcBranch.BoundText)) = False Then
                                GoTo ErrTrap
                            End If
    
                        End If

                    Next i

                End With

            End If
        End If
    End If

    Dim StrSQL  As String
    StrSQL = "UPDATE Transactions SET NOTS=" & val(Me.Text1.text) & " WHERE Transaction_ID=" & val(Me.XPTxtBillID.text)
    'sql = "update transactions set closed=1" & ",nots=" & Val(Me.XPTxtBillID.text) & ",nots2=" & Me.TxtNoteSerial1.text & " where  Transaction_ID= " & Val(Me.Text1.text)
    Cn.Execute StrSQL
    IsVouc = True
    Exit Function
ErrTrap:
IsVouc = False
End Function




Private Function CheckCreditLimitSalesMan() As Boolean
Dim s As String
Dim rsDummy As New ADODB.Recordset
Dim Balance  As Double
Dim BalanceStore  As Double
Dim FirstPeriod As Date
Dim LastPeriod As Date
s = "Select Account_Code from TblBoxesData Where empid = " & val(DcEmp.BoundText)
rsDummy.Open s, Cn, adOpenStatic, adLockReadOnly
If Not rsDummy.EOF Then
    getFirstPeriodDateInthisYear FirstPeriod
    Balance = GetActualAccountBalance(Trim(rsDummy!Account_code & ""), 0, FirstPeriod, Date)
End If

rsDummy.Close

s = " SELECT  SUM((oldopening+openingValue +inputvalue+outputValue) * cost) as BalanceStore"
s = s & " From"
s = s & " ("

s = s & " SELECT ISNULL(QryItemsInventry3.outputValue, 0) AS outputValue,"
s = s & "        ISNULL(QryItemsInventry3.inputvalue, 0) AS inputvalue,"
s = s & "        ISNULL(QryItemsInventry3.openingValue, 0) AS openingValue,"
s = s & "        Cost = ("
s = s & "            SELECT UnitSalesPrice"
s = s & "            From dbo.TblItemsUnits"
s = s & "            Where TblItemsUnits.ItemID = TblItems.ItemID"
s = s & "                   AND UnitID IN (SELECT UnitID"
s = s & "                                  From dbo.TblItemsUnits"
s = s & "                                  Where TblItemsUnits.ItemID = TblItems.ItemID"
s = s & "                                         AND DefaultUnit = 1)"
s = s & "        ),"
s = s & "        ISNULL("
s = s & "            dbo.GetItemqtytodatenew("
s = s & "                '1900-01-01',"

s = s & "                  dbo.TblItems.ItemID,"
s = s & "                                 " & val(DCboStoreName.BoundText) & ","
s = s & "                 NULL,"
s = s & "                 NULL,"
s = s & "                 NULL,"
s = s & "                 NULL,"
s = s & "                 NULL"
s = s & "             ),"
s = s & "  0"
s = s & "         ) AS oldopening"

s = s & "  FROM   dbo.QryItemsInventry3("
s = s & "                '1900-01-01',"
s = s & "                           GETDATE(),"
s = s & "                                 " & val(DCboStoreName.BoundText) & ","
s = s & "            NULL,"
s = s & "            NULL,"
s = s & "            NULL,"
s = s & "            NULL,"
s = s & "            NULL"
s = s & "        ) QryItemsInventry3"
s = s & "        RIGHT OUTER JOIN dbo.TblItems"
s = s & "             ON  QryItemsInventry3.Item_ID = dbo.TblItems.ItemID"
s = s & "        INNER JOIN dbo.Groups"
s = s & "             ON  dbo.Groups.GroupID = dbo.TblItems.GroupID"
s = s & " Where 1 = 1"
s = s & "        and ItemType <> 1 AND  TblItems.ItemID  IN (SELECT DISTINCT dbo.Transaction_Details.Item_ID"
s = s & "                                 From dbo.transactions"
s = s & "                                        INNER JOIN dbo.TransactionTypes"
s = s & "                                             ON  dbo.Transactions.Transaction_Type = dbo.TransactionTypes.Transaction_Type"
s = s & "                                        INNER JOIN dbo.Transaction_Details"
s = s & "                                             ON  dbo.Transactions.Transaction_ID = dbo.Transaction_Details.Transaction_ID"
s = s & "                                 Where (dbo.TransactionTypes.StockEffect <> 0)"
s = s & "                                        AND (dbo.Transactions.StoreID = " & val(DCboStoreName.BoundText) & "  ))"

s = s & "  ) T"

rsDummy.Open s, Cn, adOpenStatic, adLockReadOnly
If Not rsDummy.EOF Then
    BalanceStore = val(rsDummy!BalanceStore & "")
End If
rsDummy.Close

s = "Select CreditLimitSalesMan from tblusers Where UserId = " & user_id
rsDummy.Open s, Cn, adOpenStatic, adLockReadOnly
Dim mCreditLimitSalesMan As Double
If Not rsDummy.EOF Then
    mCreditLimitSalesMan = val(rsDummy!CreditLimitSalesMan & "")
End If

If mCreditLimitSalesMan = 0 Then CheckCreditLimitSalesMan = True: Exit Function
If BalanceStore + Balance + LblTotalView > mCreditLimitSalesMan Then
    If SystemOptions.UserInterface = ArabicInterface Then
        MsgBox "لا يمكن حفظ وانشاء الطلب الداخلى لتخطى الحد الائتمانى للمندوب"
    Else
        MsgBox "The internal order cannot be saved and created to exceed the delegate's credit limit"
    End If
    CheckCreditLimitSalesMan = False
    Exit Function
End If
CheckCreditLimitSalesMan = True

End Function

