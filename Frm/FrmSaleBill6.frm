Public Sub CalcValueGrids()

If mTypeInvoice = 1 Then Exit Sub
Dim i As Long
Dim j As Long
Dim jj As Long
Dim mValue As Double

mCash = 0
mMada = 0
mVisa = 0
mCredit = 0

Dim mItemId As Long
Grid.rows = 5
Grid2.rows = 5
With Grid
    For i = 1 To .rows - 1
       .TextMatrix(i, .ColIndex("Qty")) = ""
    Next i
End With

With Grid2
    For i = 1 To .rows - 1
       .TextMatrix(i, .ColIndex("Qty")) = ""
    Next i
End With


With FG
    For i = 1 To .rows - 1
        mItemId = val(.TextMatrix(i, .ColIndex("Code")))
        mValue = val(.TextMatrix(i, .ColIndex("Count")))
        For j = 1 To Grid.rows - 1
            If mItemId = val(Grid.TextMatrix(j, Grid.ColIndex("ItemID"))) Then
                Grid.TextMatrix(j, Grid.ColIndex("Qty")) = val(Grid.TextMatrix(j, Grid.ColIndex("Qty"))) + mValue
            End If
        Next j
        mCash = mCash + val(.TextMatrix(i, .ColIndex("Cash")))
        mMada = mMada + val(.TextMatrix(i, .ColIndex("Mada")))
        mVisa = mVisa + val(.TextMatrix(i, .ColIndex("Visa")))
        mCredit = mCredit + val(.TextMatrix(i, .ColIndex("Deferred")))
        
         
        
    Next i
End With

        Grid2.TextMatrix(1, Grid2.ColIndex("Qty")) = mCash
        Grid2.TextMatrix(2, Grid2.ColIndex("Qty")) = mVisa
        Grid2.TextMatrix(3, Grid2.ColIndex("Qty")) = mMada
        Grid2.TextMatrix(4, Grid2.ColIndex("Qty")) = mCredit


End Sub

