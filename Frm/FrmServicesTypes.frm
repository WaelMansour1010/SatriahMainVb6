Private Sub btnSave_Click()
    On Error GoTo ErrTrap
    Dim Msg As String
    Dim StrVacCode As String
    Dim StrVacName As String
    Dim CtrlTxt As Control

    '---------------------- check if data Vaclete -----------------------
    If Trim(Me.TxtVacName.text) = "" Then
        Msg = "يجب كتابة اسم الخدمة ...!!!"
        MsgBox Msg, vbExclamation + vbMsgBoxRight + vbMsgBoxRtlReading, App.title
        TxtVacName.SetFocus
        Exit Sub
    End If
    
    If val(Me.TxtCost.text) = 0 Then
        Msg = "يجب كتابة قيمة تكلفة الخدمة ...!!!"
        MsgBox Msg, vbExclamation + vbMsgBoxRight + vbMsgBoxRtlReading, App.title
        TxtCost.SetFocus
        Exit Sub
    End If

    '------------------------------ check if Empcode exist ----------------------
    StrVacName = IsRecExist("TblServices", "ServiceName", Trim(TxtVacName.text), "ServiceName", "ServiceID<>'" & Trim(TxtServiceID.text) & "'")

    If StrVacName <> "" Then
        Msg = "لقد سبق تسجيل هذه الخدمة من قبل"
        MsgBox Msg, vbOKOnly + vbMsgBoxRight, App.title
        TxtVacName.SetFocus
        Exit Sub
    End If

    ' -------------------------------------- txtmodflg type -------------------
    Select Case Me.TxtModFlg.text

            '------------------------------ new record ----------------------------
        Case "N"
      
            '------------------------- save record -----------------------------
            AddNewRec
            BtnLast_Click

        Case "E"

            '----------------------------- save edit -------------------------------
            FiLLRec
    End Select

    Exit Sub
ErrTrap:
    MsgBox "هناك خطأ ما في إدخال البيانات", vbOKOnly + vbMsgBoxRight, App.title

End Sub
 
