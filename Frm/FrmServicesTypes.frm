Public Sub FiLLRec()
    On Error GoTo ErrTrap

    RsSavRec.Fields("ServiceName").value = IIf(TxtVacName.text <> "", Trim(TxtVacName.text), Null)
    RsSavRec.Fields("ServiceCost").value = IIf(TxtCost.text <> "", val(TxtCost.text), Null)
    'RsSavRec.Fields("UserID").Value = IIf(StrUserID <> "", Val(StrUserID), Val(StrUserID))

    RsSavRec.update
    MsgBox "تمت عملية الحفظ بنجاح", vbOKOnly + vbMsgBoxRight, App.title
    FillGridWithData
    TxtModFlg = "R"

    Exit Sub
ErrTrap:

    If RsSavRec.EditMode <> adEditNone Then
        RsSavRec.CancelUpdate
    End If

End Sub

Public Sub FiLLTXT()

    On Error GoTo ErrTrap
    Dim i As Integer
    Frm2.Enabled = False
    TxtServiceID.text = IIf(IsNull(RsSavRec.Fields("ServiceID").value), "", RsSavRec.Fields("ServiceID").value)

    TxtVacName.text = IIf(IsNull(RsSavRec.Fields("ServiceName").value), "", RsSavRec.Fields("ServiceName").value)
    TxtCost.text = IIf(IsNull(RsSavRec.Fields("ServiceCost").value), "", RsSavRec.Fields("ServiceCost").value)
    LabCurrRec.Caption = RsSavRec.AbsolutePosition
    LabCountRec.Caption = RsSavRec.RecordCount

    With Grid

        For i = 1 To .Rows - 1

            If Trim(TxtServiceID.text) = .TextMatrix(i, .ColIndex("ServiceID")) Then
                .Row = i
                Exit Sub
            End If

        Next

    End With

ErrTrap:

End Sub

