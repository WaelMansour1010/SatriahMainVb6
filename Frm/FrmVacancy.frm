Private Sub btnDelete_Click()
    On Error GoTo ErrTrap

    Dim MSGType As Integer
    Dim BlnRecExist As Boolean
    Dim StrMSG  As String
    Dim Msg As String
    On Error GoTo ErrTrap

    If DoPremis(Do_Delete, Me.Name, True) = False Then
        Exit Sub
    End If

    If TxtVac_ID.text <> "" Then
    If SystemOptions.UserInterface = ArabicInterface Then
        MSGType = MsgBox("ĺá ĘŃŰČ Ýí ÍĐÝ ĺĐÇ ÇáÓĚá", vbYesNo + vbMsgBoxRight, App.Title)
        Else
        MSGType = MsgBox("Confirm Delete?", vbYesNo + vbMsgBoxRight, App.Title)
        End If

        If MSGType = vbYes Then
            RsSavRec.Find "Vac_ID=" & val(TxtVac_ID.text), , adSearchForward, 1
            CuurentLogdata ("D")
            RsSavRec.delete
           If SystemOptions.UserInterface = ArabicInterface Then
            MsgBox "ĘăĘ ÚăáíÉ ÇáÍĐÝ ČäĚÇÍ", vbOKOnly + vbMsgBoxRight, App.Title
            Else
            MsgBox "Delete Succeesfully", vbOKOnly + vbMsgBoxRight, App.Title
           End If
            
            '------------------------------ Move Next ---------------------------.
            FillGridWithData
            BtnNext_Click
        End If
    End If

    Exit Sub
ErrTrap:
 
    Select Case Err.Number

        Case -2147217873, -2147467259
        If SystemOptions.UserInterface = ArabicInterface Then
            StrMSG = "ÚÝćÇ áÇ íĚćŇ ÍĐÝ ÇáÓĚá áÇŃĘČÇŘĺ ČČíÇäÇĘ ĂÎŃí"
            Else
            StrMSG = "Sorry...you can not delete this record .its association with other data"
            End If
            RsSavRec.CancelUpdate
            MsgBox StrMSG, vbOKOnly + vbMsgBoxRight, App.Title
            'clear the ConnectiOn Errors
            Cn.Errors.Clear
    End Select

End Sub

