Public Sub FiLLRec()
    On Error GoTo ErrTrap

    RsSavRec.Fields("Vac_Name").value = IIf(TxtVacName.text <> "", Trim(TxtVacName.text), Null)
    RsSavRec.Fields("Dis_Count").value = IIf(TxtDis_Count.text <> "", Trim(TxtDis_Count.text), Null)
    RsSavRec.Fields("NameE").value = IIf(TxtVacNameE.text <> "", Trim(TxtVacNameE.text), Null)
    RsSavRec.Fields("NoDay").value = IIf(TxtNoDay.text <> "", val(TxtNoDay.text), Null)
    RsSavRec.Fields("MaxDay").value = IIf(TxtMaxDay.text <> "", Trim(TxtMaxDay.text), Null)
    RsSavRec.Fields("ComponentID").value = val(DCComponent.BoundText)
    RsSavRec.Fields("Account_Code").value = Trim(cmbAccountCode.BoundText)
    
    
    'RsSavRec.Fields("UserID").Value = IIf(StrUserID <> "", Val(StrUserID), Val(StrUserID))
   If VacAretha.value = vbChecked Then
   RsSavRec.Fields("VacAretha").value = 1
   Else
   RsSavRec.Fields("VacAretha").value = Null
   End If
    RsSavRec.update
    If SystemOptions.UserInterface = ArabicInterface Then
    MsgBox "ĘăĘ ÚăáíÉ ÇáÍÝŮ ČäĚÇÍ", vbOKOnly + vbInformation + vbMsgBoxRtlReading + vbMsgBoxRight, App.Title
    Else
    MsgBox "Save SuccessFully", vbOKOnly + vbInformation + vbMsgBoxRtlReading + vbMsgBoxRight, App.Title
    End If
    CuurentLogdata
    FillGridWithData
    TxtModFlg = "R"

    Exit Sub
ErrTrap:

    If RsSavRec.EditMode <> adEditNone Then
        RsSavRec.CancelUpdate
    End If

End Sub

Public Sub FiLLTXT()

    On Error GoTo ErrTrap
    Dim i As Integer
    Frm2.Enabled = False
    TxtVac_ID.text = IIf(IsNull(RsSavRec.Fields("Vac_ID").value), "", RsSavRec.Fields("Vac_ID").value)
    TxtVacName.text = IIf(IsNull(RsSavRec.Fields("Vac_Name").value), "", RsSavRec.Fields("Vac_Name").value)
    TxtDis_Count.text = IIf(IsNull(RsSavRec.Fields("Dis_Count").value), "", RsSavRec.Fields("Dis_Count").value)
    TxtNoDay.text = IIf(IsNull(RsSavRec.Fields("NoDay").value), "", RsSavRec.Fields("NoDay").value)
    TxtMaxDay.text = IIf(IsNull(RsSavRec.Fields("MaxDay").value), "", RsSavRec.Fields("MaxDay").value)
    TxtVacNameE.text = IIf(IsNull(RsSavRec.Fields("NameE").value), "", RsSavRec.Fields("NameE").value)
    DCComponent.BoundText = IIf(IsNull(RsSavRec.Fields("ComponentID").value), "", RsSavRec.Fields("ComponentID").value)
    
    cmbAccountCode.BoundText = IIf(IsNull(RsSavRec("Account_Code").value), "", RsSavRec("Account_Code").value)
    
    If Not IsNull(RsSavRec.Fields("VacAretha").value) Then
    If (RsSavRec.Fields("VacAretha").value) = 1 Then
    VacAretha.value = vbChecked
    Else
    VacAretha.value = vbUnchecked
    End If
    Else
    VacAretha.value = vbUnchecked
    End If
    LabCurrRec.Caption = RsSavRec.AbsolutePosition
    LabCountRec.Caption = RsSavRec.RecordCount

    With Grid

        For i = 1 To .rows - 1

            If Trim(TxtVac_ID.text) = .TextMatrix(i, .ColIndex("Vac_ID")) Then
                TxtSerial.text = .TextMatrix(i, .ColIndex("Ser"))
                .row = i
                Exit Sub
            End If

        Next

    End With

ErrTrap:

End Sub

