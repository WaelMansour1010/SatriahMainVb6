Private Sub Command1_Click(Index As Integer)

    With Me.VSFlexGrid1

        If Not Text1(2).text = "" Then
            WebBrowser2.Navigate2 Text1(2).text
 
            XPTab301.CurrTab = 1
        End If

    End With

