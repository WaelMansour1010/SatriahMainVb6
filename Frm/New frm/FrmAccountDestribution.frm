Public Sub Retrive(Optional Lngid As Long = 0)
    Dim RsDev As ADODB.Recordset
    Dim RsDev1 As ADODB.Recordset
    Dim StrSQL As String
    Dim i As Integer

    'On Error GoTo ErrTrap
    Grid.Clear flexClearScrollable, flexClearEverything
    Grid.Rows = 1
          
    If rs.RecordCount < 1 Then
        Exit Sub
    End If

    If rs.EOF Or rs.BOF Then
        Exit Sub
    Else

    End If
 
    Me.TxtTblAccountsDestributionsid.text = IIf(IsNull(rs("TblAccountsDestributionsid").value), "", rs("TblAccountsDestributionsid").value)
 
    XPDtbTrans.value = IIf(IsNull(rs("RecordDate").value), Date, rs("RecordDate").value)
  
    DCAccountMaster.BoundText = IIf(IsNull(rs("AccountMaster").value), "", rs("AccountMaster").value)

    TxtRemarks.text = IIf(IsNull(rs("Remarks").value), 0, rs("Remarks").value)

    If (rs("DistType").value) = False Then
        DistType(0).value = True
    ElseIf (rs("DistType").value) = True Then

        DistType(1).value = True
    ElseIf IsNull(rs("DistType").value) Then

        DistType(2).value = True
    End If

    If (rs("PercentagType").value) = 0 Then
        PercentagType(0).value = True
    Else
        PercentagType(1).value = True
    End If

    StrSQL = " SELECT    * from   TblAccountsDestributionsDetails "
    StrSQL = StrSQL & "  where TblAccountsDestributionsid=" & val(Me.TxtTblAccountsDestributionsid.text)
    
    Set RsDev = New ADODB.Recordset
    RsDev.Open StrSQL, Cn, adOpenStatic, adLockReadOnly, adCmdText

    If Not (RsDev.BOF Or rs.EOF) Then
        RsDev.MoveFirst
    
        With Me.Grid
    
            .Rows = .FixedRows + RsDev.RecordCount

            For i = .FixedRows To .Rows - 1
 
                .TextMatrix(i, .ColIndex("Aid")) = IIf(IsNull(RsDev("Aid").value), "", RsDev("Aid").value)
            
                .TextMatrix(i, .ColIndex("ACode")) = IIf(IsNull(RsDev("ACode").value), "", RsDev("ACode").value)
            
                .TextMatrix(i, .ColIndex("ASerial")) = IIf(IsNull(RsDev("ASerial").value), "", RsDev("ASerial").value)
                .TextMatrix(i, .ColIndex("AName")) = IIf(IsNull(RsDev("AName").value), "", RsDev("AName").value)
 
                .TextMatrix(i, .ColIndex("Percentage")) = IIf(IsNull(RsDev("Percentage").value), 0, val(RsDev("Percentage").value))
            
                .TextMatrix(i, .ColIndex("Remarks")) = IIf(IsNull(RsDev("Remarks").value), "", (RsDev("Remarks").value))
            
                RsDev.MoveNext
            Next i
 
        End With

    End If
 
    StrSQL = " SELECT    * from   TblAccountsDestributionsIntervals "
    StrSQL = StrSQL & "  where TblAccountsDestributionsid=" & val(Me.TxtTblAccountsDestributionsid.text)
    
    Set RsDev = New ADODB.Recordset
    RsDev.Open StrSQL, Cn, adOpenStatic, adLockReadOnly, adCmdText

    If Not (RsDev.BOF Or rs.EOF) Then
        RsDev.MoveFirst
    
        With Me.GridIntervals
    
            .Rows = .FixedRows + RsDev.RecordCount

            For i = .FixedRows To .Rows - 1
 
                .TextMatrix(i, .ColIndex("IntervalSerial")) = IIf(IsNull(RsDev("IntervalSerial").value), "", RsDev("IntervalSerial").value)
            
                .TextMatrix(i, .ColIndex("FromDate")) = IIf(IsNull(RsDev("FromDate").value), "", RsDev("FromDate").value)
            
                .TextMatrix(i, .ColIndex("ToDate")) = IIf(IsNull(RsDev("ToDate").value), "", RsDev("ToDate").value)
 
                If RsDev("DistributedDone").value = True Then
                    .Cell(flexcpChecked, i, .ColIndex("DistributedDone")) = flexChecked
                Else
                    .Cell(flexcpChecked, i, .ColIndex("DistributedDone")) = flexUnchecked
                End If
 
                .TextMatrix(i, .ColIndex("Remarks")) = IIf(IsNull(RsDev("Remarks").value), "", (RsDev("Remarks").value))
            
                .TextMatrix(i, .ColIndex("NoteID")) = IIf(IsNull(RsDev("NoteID").value), 0, (RsDev("Remarks").value))
            
                .TextMatrix(i, .ColIndex("NoteSerial")) = IIf(IsNull(RsDev("NoteSerial").value), "", (RsDev("NoteSerial").value))
                .TextMatrix(i, .ColIndex("PrintJL")) = "ŘČÇÚĺ"
            
                RsDev.MoveNext
            Next i
 
        End With

    End If
 
    ReLineGrid
    Exit Sub
ErrTrap:
End Sub
 
