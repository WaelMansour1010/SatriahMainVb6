    'StrSQL = StrSQL & "  dbo.TblEmployee ON dbo.TblEmpAllocationsDetails.Emp_id = dbo.TblEmployee.Emp_ID"
    'StrSQL = StrSQL & "  WHERE     (dbo.TblEmpAllocations.EmpAllocationsid = " & Val(Me.txtid.text) & ")"
 
    StrSQL = "SELECT  dbo.TblEmpAllocationsDetails.TicketValue,   dbo.TblEmpAllocationsDetails.Emp_id, dbo.TblEmployee.Fullcode, dbo.TblEmployee.Emp_Name, dbo.TblEmployee.Emp_Namee, "
    StrSQL = StrSQL & " dbo.TblEmpAllocationsDetails.[value] , dbo.TblEmpAllocationsDetails.REMARKS "
    StrSQL = StrSQL & "  FROM         dbo.TblEmpAllocations INNER JOIN"
    StrSQL = StrSQL & " dbo.TblEmpAllocationsDetails ON"
    StrSQL = StrSQL & " dbo.TblEmpAllocations.EmpAllocationsid = dbo.TblEmpAllocationsDetails.EmpAllocationsid INNER JOIN"
    StrSQL = StrSQL & "  dbo.TblEmployee ON dbo.TblEmpAllocationsDetails.Emp_id = dbo.TblEmployee.Emp_ID"
    StrSQL = StrSQL & "  WHERE     (dbo.TblEmpAllocations.EmpAllocationsid = " & val(Me.txtid.Text) & ")"
    
