                .TextMatrix(i, .ColIndex("TicketValue")) = IIf(IsNull(RsDev("TicketValue").value), 0, (RsDev("TicketValue").value))
                
              
                .TextMatrix(i, .ColIndex("remarks")) = IIf(IsNull(RsDev("remarks").value), "", RsDev("remarks").value)
  
          
            MonthDayNo = DateDiff("d", Me.xpdtbfrom.value, Me.XPDtpTo.value, vbSaturday)
            .TextMatrix(i, .ColIndex("NoofDays")) = MonthDayNo
        

                RsDev.MoveNext
            Next i

            LBLSUM.Caption = .Aggregate(flexSTSum, .FixedRows, .ColIndex("Value"), .rows - 1, .ColIndex("Value"))
            .AutoSize 0, .Cols - 1, False
        End With

    End If
 
    LabCurrRec.Caption = rs.AbsolutePosition
    LabCountRec.Caption = rs.RecordCount
    ReLineGrid
    Exit Sub
ErrTrap:
End Sub

Private Sub RemoveGridRow()

    With Me.Grid

        If .Row <= 0 Then Exit Sub
        .RemoveItem .Row
    End With

    ReLineGrid
End Sub

