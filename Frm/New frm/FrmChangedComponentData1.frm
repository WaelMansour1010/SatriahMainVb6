Dim branchFilter As String

If val(cmdActivity.BoundText) <> 0 And Trim$(cmdActivity.Text) <> "" Then
    ' ð· —… Õ”» «·‰‘«ÿ -> «·ð—Ê⁄ «· «»⁄… ·Â
    branchFilter = " And T1.Branch_NO In (SELECT branch_id FROM TblBranchesData WHERE ActivityTypeId = " & val(cmdActivity.BoundText) & ")"
Else
    ' ð· —… ⁄«œÌ… Õ”» «·ð—⁄ ðÞÿ
    branchFilter = " And T1.Branch_NO = " & val(dcBranch.BoundText)
End If

s = "SELECT T1.MONTH, T1.YEAR, T2.EMp_Id, T1.AllocationsType, T1.Branch_NO"
