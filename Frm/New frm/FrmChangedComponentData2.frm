Public Sub Retrive(Optional Lngid As Long = 0)
    'Exit Sub
    Dim RsDev As ADODB.Recordset
    Dim StrSQL As String
    Dim i As Integer

    'On Error GoTo ErrTrap
    Grid.Clear flexClearScrollable, flexClearEverything
    Grid.Rows = 1
 
    If rs.RecordCount < 1 Then
        LabCurrRec.Caption = 0
        LabCountRec.Caption = 0
        Exit Sub
    End If
 
    If rs.EOF Or rs.BOF Then
        Exit Sub
    Else

    End If

    Me.txtid.Text = IIf(IsNull(rs("SpecificComponentId").value), "", (rs("SpecificComponentId").value))
 
    DCComponent.BoundText = IIf(IsNull(rs("ComponentID").value), "", rs("ComponentID").value)
 
    StrSQL = " SELECT     dbo.tblSpecificComponentDetails.ComponentID, dbo.tblSpecificComponentDetails.Remarks, dbo.mofrad.name, dbo.mofrad.nameE, dbo.tblSpecificComponentDetails.Equation"
    StrSQL = StrSQL & "  FROM         dbo.tblSpecificComponentDetails LEFT OUTER JOIN"
    StrSQL = StrSQL & "  dbo.mofrad ON dbo.tblSpecificComponentDetails.ComponentID = dbo.mofrad.id"
    StrSQL = StrSQL & "   Where (dbo.tblSpecificComponentDetails.SpecificComponentId = " & val(Me.txtid.Text) & ")"
    
    Set RsDev = New ADODB.Recordset
    RsDev.Open StrSQL, Cn, adOpenStatic, adLockReadOnly, adCmdText

    If Not (RsDev.BOF Or rs.EOF) Then
        RsDev.MoveFirst
    
        With Me.Grid
    
            .Rows = .FixedRows + RsDev.RecordCount

            For i = .FixedRows To .Rows - 1
            
                .TextMatrix(i, .ColIndex("Emp_Code")) = IIf(IsNull(RsDev("ComponentID").value), 0, val(RsDev("ComponentID").value))
                .TextMatrix(i, .ColIndex("Equation")) = IIf(IsNull(RsDev("Equation").value), 1, (RsDev("Equation").value))

                If SystemOptions.UserInterface = ArabicInterface Then
                    .TextMatrix(i, .ColIndex("Emp_Name")) = IIf(IsNull(RsDev("name").value), 0, (RsDev("name").value))
                Else
                    .TextMatrix(i, .ColIndex("Emp_Name")) = IIf(IsNull(RsDev("namee").value), 0, (RsDev("namee").value))
            
                End If
              
                .TextMatrix(i, .ColIndex("Remarks")) = IIf(IsNull(RsDev("Remarks").value), "", RsDev("Remarks").value)
  
                RsDev.MoveNext
            Next i
     
            .AutoSize 0, .Cols - 1, False
        End With

    End If
 
    LabCurrRec.Caption = rs.AbsolutePosition
    LabCountRec.Caption = rs.RecordCount
 
    Exit Sub
ErrTrap:
End Sub

