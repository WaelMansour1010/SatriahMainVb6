Function cal_interval(date1 As Date, date2 As Date) As Double
    Dim astrSplitItems() As String
    Dim Result As String
    Dim txtYear  As Double
    Dim TxtMonth As Double
    Dim txtDay As Double
    Dim Total As Double
    Dim interval1 As Double
    Dim interval2 As Double

    Dim diff_year As Integer
    Result = ExactAge(date1, date2)

    If Result = "" Then
        cal_interval = 0
    End If

    astrSplitItems = Split(Result, "-")
    txtYear = astrSplitItems(0)
    TxtMonth = astrSplitItems(1)
    txtDay = astrSplitItems(2)
 
    If txtYear < 5 Then
    
        cal_interval = 0.5
    ElseIf txtYear >= 5 And TxtMonth > 0 Then
        cal_interval = 1
    End If
  
End Function

Private Sub SaveData()
    Dim Msg As String
    Dim RsTemp As New ADODB.Recordset
    Dim StrSQL As String
    Dim BeginTrans As Boolean
    Dim RsDev As ADODB.Recordset
    Dim LngDevID As Long
    Dim cProgress As ClsProgress
    On Error GoTo ErrTrap

    If Me.TxtModFlg.Text <> "R" Then
  
        If Trim(Me.DCComponent.BoundText) = "" Then
            If SystemOptions.UserInterface = ArabicInterface Then
                Msg = "нМИ ЕОКнЗС ЗбгЭСП..!!"
            Else
                Msg = "Must Select Component    ..!!"
            End If

            MsgBox Msg, vbOKOnly + vbInformation + vbMsgBoxRight + vbMsgBoxRtlReading, App.title
            DCComponent.SetFocus
            SendKeys "{F4}"
            Exit Sub
        End If
 
    End If
 
    With Me.Grid

        If .Rows = .FixedRows Then
            If SystemOptions.UserInterface = ArabicInterface Then
                Msg = "нМИ гЭСП жЗНП Ъбм ЗбЗЮб  ..!!"
            Else
                Msg = "Must Select At least One Component    ..!!"
            End If

            MsgBox Msg, vbOKOnly + vbInformation + vbMsgBoxRight + vbMsgBoxRtlReading, App.title
            Exit Sub
        End If
                         
    End With
 
    '-------------------------------------------------------------------------------------------
    Dim FixedSalary As Double
    Dim ChangedSalary As Double
    Dim EmployeeSalary As Double
    Dim wherestr As String
    Dim DiviMonth As Integer
    Dim NoOfHours As Double
    Dim NoOfMinutes As Double
    Dim Issue_date As Date
    Dim MultiplicationFactor As Double
    Dim i As Long

    Cn.BeginTrans
    BeginTrans = True

    If TxtModFlg.Text = "N" Then
            Me.txtid.Text = CStr(new_id("tblSpecificComponent", "SpecificComponentId", "", True))
        rs.AddNew
        rs("SpecificComponentId").value = val(Me.txtid.Text)
     
    ElseIf Me.TxtModFlg.Text = "E" Then
        StrSQL = "Delete From tblSpecificComponentDetails Where SpecificComponentId=" & val(Me.txtid.Text)
        Cn.Execute StrSQL, , adExecuteNoRecords
        
    End If
      
    rs("ComponentID").value = val(DCComponent.BoundText)
  
    rs.update
    
    Dim IntDEV_Type As Integer
    Dim SngDEV_Value As Single
         
    Dim RsSerial As ADODB.Recordset
 
    Dim LngSerialCount As Long
 
    Set RsDev = New ADODB.Recordset
    RsDev.Open "tblSpecificComponentDetails", Cn, adOpenStatic, adLockOptimistic, adCmdTable
 
    With Me.Grid

        For i = .FixedRows To .Rows - 1

            If .TextMatrix(i, .ColIndex("Emp_Code")) <> "" Then

                RsDev.AddNew
 
                RsDev("SpecificComponentId").value = val(txtid.Text)
  
                RsDev("ComponentID").value = .TextMatrix(i, .ColIndex("Emp_Code"))
               RsDev("Equation").value = val(.TextMatrix(i, .ColIndex("Equation")))
                RsDev("remarks").value = .TextMatrix(i, .ColIndex("remarks"))
     
                RsDev.update
                    
            End If
       
            '        End If
        Next i

    End With
 
    Cn.CommitTrans
    BeginTrans = False
 
    Select Case Me.TxtModFlg.Text

        Case "N"

            If SystemOptions.UserInterface = ArabicInterface Then
                Msg = " Кг НЭЩ ИнЗдЗК еРе ЗбЪгбнЙ " & CHR(13)
                Msg = Msg + "еб КСЫИ Эн ЕЦЗЭЙ ИнЗдЗК ГОСн"
            Else
                Msg = " Operation Saved Successfully " & CHR(13)
                Msg = Msg + "Do You Want New Operation"
            End If
        
            '    Fg_Journal.Enabled = False
            If MsgBox(Msg, vbYesNo + vbQuestion + vbMsgBoxRight + vbMsgBoxRtlReading + vbDefaultButton2, App.title) = vbYes Then
                Cmd_Click (0)
                Exit Sub
            End If

        Case "E"

            If SystemOptions.UserInterface = ArabicInterface Then
                MsgBox "Кг НЭЩ еРе ЗбКЪПнбЗК", vbInformation + vbOKOnly + vbMsgBoxRight + vbMsgBoxRtlReading, App.title
            Else
                MsgBox "Saved Successfully", vbInformation + vbOKOnly + vbMsgBoxRight + vbMsgBoxRtlReading, App.title
            End If

            '  Fg_Journal.Enabled = False
    End Select

    TxtModFlg.Text = "R"
    'End If

    Exit Sub
ErrTrap:

    If BeginTrans = True Then
        BeginTrans = False
        Cn.RollbackTrans
    End If

    If Err.Number = -2147217900 Then
        Msg = "бЗ нгЯд НЭЩ еРе ЗбИнЗдЗК " & CHR(13)
        Msg = Msg + "бЮП Кг ЗПОЗб Юнг ЫнС ХЗбНЙ " & CHR(13)
        Msg = Msg + "КГЯП гд ПЮЙ ЗбИнЗдЗК жГЪП ЗбгНЗжбЙ"
        MsgBox Msg, vbOKOnly + vbExclamation + vbMsgBoxRight + vbMsgBoxRtlReading, App.title
        Exit Sub
    End If

    Msg = "ЪЭжЗ...НПЛ ОШГ гЗ ГЛдЗБ НЭЩ еРе ЗбИнЗдЗК " & CHR(13)
    MsgBox Msg, vbOKOnly + vbExclamation + vbMsgBoxRight + vbMsgBoxRtlReading, App.title
End Sub

