Private Sub Cmd_Click(Index As Integer)
    On Error GoTo ErrTrap

    Select Case Index

        Case 0
            'If DoPremis(Do_New, Me.name, True) = False Then
            '    Exit Sub
            'End If
 
            clear_all Me
            TxtModFlg.Text = "N"

        
            ' Me.DCboUserName.BoundText = user_id
 
            Grid.Clear flexClearScrollable, flexClearEverything
            Grid.Rows = 2
            Grid.Enabled = True
DCComponent.BoundText = mofradId
        Case 1
            If val(txtid.Text) = 0 Then
                        If SystemOptions.UserInterface = ArabicInterface Then
                        MsgBox "бЗ нжМП УМб бКЪПнбЙ ЗЦЪШ МПнП ", vbCritical
                        Else
                        MsgBox " There is no record  Click to Add", vbCritical
                        End If
                        
                        Exit Sub
            End If
            Me.TxtModFlg.Text = "E"
        
            Grid.Rows = Grid.Rows + 1
            Grid.Enabled = True

        Case 2
            DCComponent_Change
            SaveData
           
        Case 3
            Undo

        Case 4

            If DoPremis(Do_Delete, Me.Name, True) = False Then
                Exit Sub
            End If

            Del_Trans

        Case 5

            If DoPremis(Do_Search, Me.Name, True) = False Then
                Exit Sub
            End If

            Load FrmNotesSearch
            FrmNotesSearch.SearchType = 3
            FrmNotesSearch.show vbModal

        Case 6
            Unload Me
 
        Case 21
            RemoveGridRow
          
    End Select

    Exit Sub
ErrTrap:

End Sub

Private Sub Del_Trans()
    Dim Msg As String
    Dim StrSQL As String
    On Error GoTo ErrTrap

    If CheckComponentsIntransactions(val(Me.DCComponent.BoundText)) = True Then

        If SystemOptions.UserInterface = ArabicInterface Then
            Msg = "бЗ нгЯд НРЭ еРЗ ЗбгЭСП бжМжП НСЯЗК ЪбнЙ " & CHR(13)
            
        Else
            Msg = "Can't Remove This Components It have an Transactions  " & CHR(13)
            
        End If

        MsgBox Msg, vbCritical

        Exit Sub
    End If

    If Me.txtid.Text <> "" Then
        Msg = "УнКг НРЭ ИнЗдЗК ЗбЪгбнЙ СЮг " & CHR(13)
        Msg = Msg + (TxtNoteSerial1.Text) & CHR(13)
        Msg = Msg + " еб КСЫИ Эн НРЭ еРе ЗбИнЗдЗКї"

        If MsgBox(Msg, vbYesNo + vbQuestion + vbMsgBoxRight + vbMsgBoxRtlReading, App.title) = vbYes Then

            StrSQL = "Delete From tblSpecificComponentDetails Where SpecificComponentId=" & val(Me.txtid.Text)
            Cn.Execute StrSQL, , adExecuteNoRecords
 
            If Not rs.RecordCount < 1 Then
                rs.delete
                rs.MoveFirst

                If rs.RecordCount < 1 Then
                    clear_all Me
                    LabCurrRec.Caption = 0
                    LabCountRec.Caption = 0
                
                    Grid.Clear flexClearScrollable, flexClearEverything
                    Grid.Rows = 1
                 
                    TxtModFlg_Change
           
                Else
                    Retrive
                End If
            End If
        End If

    Else
        clear_all Me
        Msg = "еРе ЗбЪгбнЙ ЫнС гКЗНЙ НнЛ Где бЗнжМП Гн УМбЗК"
        MsgBox Msg, vbOKOnly + vbExclamation + vbMsgBoxRight + vbMsgBoxRtlReading, App.title
        TxtModFlg_Change
        Exit Sub
    End If

    TxtModFlg_Change
    Exit Sub
ErrTrap:
    Msg = "ЪЭжЗ...НПЛ ОШГ гЗ ГЛдЗБ НРЭ еРе ЗбИнЗдЗК " & CHR(13)
    MsgBox Msg, vbMsgBoxRight + vbMsgBoxRtlReading + vbExclamation, App.title
    rs.CancelUpdate
End Sub
 
