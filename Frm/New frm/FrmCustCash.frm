    RsSavRec.update
 If SystemOptions.UserInterface = ArabicInterface Then
    MsgBox "تمت عملية الحفظ بنجاح", vbInformation + vbOKOnly + vbMsgBoxRight + vbMsgBoxRtlReading, App.title
