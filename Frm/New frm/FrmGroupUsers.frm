Private Sub btnModify_Click()
    Dim Msg As String

    If DoPremis(Do_Edit, Me.name, True) = False Then
        Exit Sub
    End If

    On Error GoTo ErrTrap

    If TxtVac_ID.text <> "" Then
        TxtModFlg = "E"
        VSFlexGrid1.Rows = VSFlexGrid1.Rows + 1
