Private Sub XPBtnMove_Click(Index As Integer)
    On Error GoTo ErrTrap

    If Me.TxtModFlg.Text = "N" Then
        clear_all Me
        Me.TxtModFlg.Text = "R"
        XPBtnMove_Click (1)
    End If

    Select Case Index

        Case 0

            If Not (rs.EOF Or rs.BOF) Then
                rs.MovePrevious

                If rs.BOF Then rs.MoveFirst
            End If

        Case 1

            If Not (rs.EOF Or rs.BOF) Then
                rs.MoveFirst
            End If

        Case 2

            If Not (rs.EOF Or rs.BOF) Then
                rs.MoveLast
            End If

        Case 3

            If Not (rs.EOF Or rs.BOF) Then
                rs.MoveNext

                If rs.EOF Then rs.MoveLast
            End If

    End Select

    Retrive
    Exit Sub
ErrTrap:
End Sub

Function FillGridWithData(sizeid As Integer)
    Dim StrSQL As String
 
    StrSQL = "SELECT     TOP 100 PERCENT dbo.TblItemsclassesDetails.MinValue, dbo.TblItemsclassesDetails.maxvalue, dbo.TblItemsclassesDetails.SizeId, dbo.TblQCItems.name, "
    StrSQL = StrSQL + "   dbo.TblQCItems.namee , dbo.TblQCItems.Comment, dbo.TblQCItems.Grade, dbo.TblItemsclassesDetails.qcid"
    StrSQL = StrSQL + "  FROM         dbo.TblItemsclassesDetails INNER JOIN"
    StrSQL = StrSQL + "  dbo.TblQCItems ON dbo.TblItemsclassesDetails.qcid = dbo.TblQCItems.qcid"
    StrSQL = StrSQL + "   Where (dbo.TblItemsclassesDetails.sizeid = " & sizeid & ")"
    StrSQL = StrSQL + "  ORDER BY dbo.TblItemsclassesDetails.id"

    Dim RsDev As New ADODB.Recordset
    RsDev.Open StrSQL, Cn, adOpenStatic, adLockReadOnly, adCmdText

    If RsDev.RecordCount > 0 Then
        RsDev.MoveFirst
    End If
 
    Dim i As Integer
 
    With Me.Fg_Journal
 
        .Rows = .FixedRows + RsDev.RecordCount
 
        For i = .FixedRows To .Rows - 1
            .TextMatrix(i, .ColIndex("LineNo")) = i
            .TextMatrix(i, .ColIndex("AccountCode")) = IIf(IsNull(RsDev("qcid").value), "", RsDev("qcid").value)

            If SystemOptions.UserInterface = ArabicInterface Then
                .TextMatrix(i, .ColIndex("AccountName")) = IIf(IsNull(RsDev("name").value), "", RsDev("name").value)
            Else
                .TextMatrix(i, .ColIndex("AccountName")) = IIf(IsNull(RsDev("namee").value), "", RsDev("namee").value)
            End If
          
            .TextMatrix(i, .ColIndex("MinValue")) = IIf(IsNull(RsDev("MinValue").value), "", RsDev("MinValue").value)
            
            .TextMatrix(i, .ColIndex("maxvalue")) = IIf(IsNull(RsDev("maxvalue").value), "", RsDev("maxvalue").value)
            RsDev.MoveNext
        Next i

    End With

End Function

