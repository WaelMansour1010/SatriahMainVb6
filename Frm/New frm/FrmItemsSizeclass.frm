Public Sub Retrive(Optional Lngid As Long = 0)
    On Error GoTo ErrTrap

    If rs.RecordCount < 1 Then
        XPTxtCurrent.Caption = 0
        XPTxtCount.Caption = 0
        Exit Sub
    End If

    Fg_Journal.Clear flexClearScrollable, flexClearEverything
    Fg_Journal.Rows = 2
          
    XPTxtBoxID.Text = IIf(IsNull(rs("SizeId").value), "", val(rs("SizeId").value))
    XPTxtBoxName.Text = IIf(IsNull(rs("SizeName").value), "", Trim(rs("SizeName").value))
    XPTxtBoxNamee.Text = IIf(IsNull(rs("SizeNameE").value), "", Trim(rs("SizeNameE").value))
    XPMTxtRemark.Text = IIf(IsNull(rs("SizeComment").value), "", Trim(rs("SizeComment").value))
    TxtDiscountPercentage.Text = IIf(IsNull(rs("DiscountPercentage").value), 0, (rs("DiscountPercentage").value))
    TxtPerfectPercentage.Text = IIf(IsNull(rs("PerfectPercentage").value), 0, (rs("PerfectPercentage").value))
    Me.DboAccount.BoundText = IIf(IsNull(rs("Account_code")), "", rs("Account_code"))
       
    XPTxtCurrent.Caption = rs.AbsolutePosition
    XPTxtCount.Caption = rs.RecordCount
    FillGridWithData (val(XPTxtBoxID.Text))
    Exit Sub
