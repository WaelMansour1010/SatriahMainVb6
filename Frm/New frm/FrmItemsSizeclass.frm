   If Fg5.Rows > 1 And Fg5.Row > 1 Then
        Fg5.Rows = Fg5.Rows + 1
        Fg5.TextMatrix(Fg5.Rows - 1, Fg5.ColIndex("EmpName")) = Fg5.TextMatrix(Fg5.Row, Fg5.ColIndex("EmpName"))
        Fg5.TextMatrix(Fg5.Rows - 1, Fg5.ColIndex("EmpID")) = Fg5.TextMatrix(Fg5.Row, Fg5.ColIndex("EmpID"))
        
        Fg5.TextMatrix(Fg5.Rows - 1, Fg5.ColIndex("ShiftTypeID")) = Fg5.TextMatrix(Fg5.Row, Fg5.ColIndex("ShiftTypeID"))
        Fg5.TextMatrix(Fg5.Rows - 1, Fg5.ColIndex("ShiftTypeName")) = Fg5.TextMatrix(Fg5.Row, Fg5.ColIndex("ShiftTypeName"))
        Fg5.TextMatrix(Fg5.Rows - 1, Fg5.ColIndex("RestsTypesID")) = Fg5.TextMatrix(Fg5.Row, Fg5.ColIndex("RestsTypesID"))
        Fg5.TextMatrix(Fg5.Rows - 1, Fg5.ColIndex("RestsTypesName")) = Fg5.TextMatrix(Fg5.Row, Fg5.ColIndex("RestsTypesName"))
        If Fg5.TextMatrix(Fg5.Row, Fg5.ColIndex("FromDate")) <> "" Then
            If KeyCode = vbKeyF4 Then
                Fg5.TextMatrix(Fg5.Rows - 1, Fg5.ColIndex("FromDate")) = DateAdd("D", 1, Fg5.TextMatrix(Fg5.Row, Fg5.ColIndex("FromDate")))
                
                
            ElseIf KeyCode = vbKeyF5 Then
                Fg5.TextMatrix(Fg5.Rows - 1, Fg5.ColIndex("FromDate")) = Fg5.TextMatrix(Fg5.Row, Fg5.ColIndex("FromDate"))
            End If
            Fg5.TextMatrix(Fg5.Rows - 1, Fg5.ColIndex("DayName")) = Weekday(Fg5.TextMatrix(Fg5.Rows - 1, Fg5.ColIndex("FromDate")), vbUseSystemDayOfWeek)
        End If
