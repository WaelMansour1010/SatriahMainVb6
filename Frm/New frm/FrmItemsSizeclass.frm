Private Function GetAge(ByVal mType As Integer) As String
    Dim d, m, Y, d1, d2, tmp, Msg
    d2 = Format(Date, "dd/mm/yyyy")
    d1 = Format(txtToDate8(2).value, "dd/mm/yyyy")
    If Not IsDate(d1) Then
        
        Exit Function
    End If
    If DateValue(d1) >= DateValue(d2) Then
       
        Exit Function
    End If
    
        Y = DateDiff("yyyy", d1, d2)
    d1 = DateAdd("yyyy", Y, d1)
    m = DateDiff("m", d1, d2)
    d1 = DateAdd("m", m, d1)
    d = DateDiff("d", d1, d2)
    
    
    If mType = 1 Then
        GetAge = Y
    ElseIf mType = 2 Then
        GetAge = m
    ElseIf mType = 3 Then
        GetAge = d

    End If


End Function

