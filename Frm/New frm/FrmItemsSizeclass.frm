Private Function GetStatusAnima(ByVal mCode As Long) As String
Dim MySQL As String
MySQL = MySQL & "            Select        StatusFinal = CASE ("
MySQL = MySQL & "                                           SELECT TOP 1 'D'"
MySQL = MySQL & "                                           From TblFarmAnimalDeath"
MySQL = MySQL & "                                           Where TblFarmAnimalDeath.FarmAnimalRegisterId = TblFarmAnimalRegister.ID"
MySQL = MySQL & "                                       )"
MySQL = MySQL & "                                       WHEN 'D' THEN N'‰ðÞ'"
MySQL = MySQL & "                                       Else"
MySQL = MySQL & "                                         ("
MySQL = MySQL & "                                                     SELECT TOP 1 NAME"
MySQL = MySQL & "                                                     FROM   ("
MySQL = MySQL & "                                                                SELECT TblStatusFarm.Name,"
MySQL = MySQL & "                                                                       RecordDate"
MySQL = MySQL & "                                                                From TblFarmAnimalRegister2"
MySQL = MySQL & "                                                                       INNER JOIN TblStatusFarm"
MySQL = MySQL & "                                                                            ON  TblStatusFarm.ID = TblFarmAnimalRegister2.StatusFarmID"
MySQL = MySQL & "                                                                            AND TblFarmAnimalRegister2.MasterID ="
MySQL = MySQL & "                                                                                TblFarmAnimalRegister.ID"
'QL = MySQL & "                                                                --ORDER BY recordDate"
''QL = MySQL & "                                                                --ORDER BY TblFarmRequestTreatment2.recordDate"
MySQL = MySQL & "                                                               Union all"
MySQL = MySQL & "                                                                SELECT TblStatusFarm.Name,"
MySQL = MySQL & "                                                                       TblFarmRequestTreatment2.RecordDate"
MySQL = MySQL & "                                                                From TblFarmRequestTreatment2"
MySQL = MySQL & "                                                                       INNER JOIN TblStatusFarm"
MySQL = MySQL & "                                                                            ON  TblStatusFarm.ID ="
MySQL = MySQL & "                                                                                TblFarmRequestTreatment2.StatusFarmID"
MySQL = MySQL & "                                                                       INNER JOIN TblFarmRequestTreatment"
MySQL = MySQL & "                                                                            ON  TblFarmRequestTreatment2.MasterID ="
MySQL = MySQL & "                                                                                TblFarmRequestTreatment.ID"
MySQL = MySQL & "                                                                WHERE  TblFarmRequestTreatment.FarmAnimalRegisterId ="
MySQL = MySQL & "                                                                       TblFarmAnimalRegister.ID"
MySQL = MySQL & "                                                            ) T"
'MySQL = MySQL & "                                                            --WHERE
MySQL = MySQL & "                                                     Order By"
MySQL = MySQL & "                                                            RecordDate desc"
MySQL = MySQL & "                                                 )"
MySQL = MySQL & "                                            End"
MySQL = MySQL & "                                            From TblFarmAnimalRegister"
MySQL = MySQL & "                                            Where TblFarmAnimalRegister.Id = " & val(mCode)

Dim rsDummy As New ADODB.Recordset
rsDummy.Open MySQL, Cn, adOpenStatic, adLockReadOnly
If Not rsDummy.EOF Then
    GetStatusAnima = rsDummy!StatusFinal & ""
End If
End Function

