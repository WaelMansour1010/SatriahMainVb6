            Grid1.Clear flexClearScrollable, flexClearEverything
            Grid1.Rows = 2
            Grid1.Enabled = True
         
            opt(0).value = True

        Case 1

            If DoPremis(Do_Edit, Me.name, True) = False Then
                Exit Sub
            End If

            TxtModFlg.text = "E"
            Grid.Rows = Grid.Rows + 1
            Grid.Enabled = True
         
            Grid1.Rows = Grid1.Rows + 1
            Grid1.Enabled = True
            CuurentLogdata

        Case 2
    
            SaveData
           
        Case 3
            Undo

        Case 4

            If DoPremis(Do_Delete, Me.name, True) = False Then
                Exit Sub
            End If

            Del_Trans

        Case 5

            If DoPremis(Do_Search, Me.name, True) = False Then
                Exit Sub
            End If

            Load FrmNotesSearch
            FrmNotesSearch.SearchType = 3
            FrmNotesSearch.show vbModal

        Case 6
            Unload Me

        Case 7

            '   ViewDataList
        Case 20
            addrow

        Case 21
            RemoveGridRow
    End Select

    Exit Sub
ErrTrap:

End Sub

