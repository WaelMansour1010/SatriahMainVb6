Private Sub Grid_AfterEdit(ByVal Row As Long, _
                           ByVal Col As Long)
    On Error Resume Next
    Dim StrAccountCode As String
    Dim Msg As String
    Dim rs As New ADODB.Recordset
    Dim StrSQL As String
    Dim ClsAcc As New ClsAccounts
    Dim LngRow As Long
    Dim code  As String

    With Grid

        Select Case .ColKey(Col)
 
            Case "UnitName"
                code = .ComboData
           
                '   LngRow = .FindRow(Code, .FixedRows, .ColIndex("UnitID"), False, True)
                .TextMatrix(Row, .ColIndex("UnitID")) = code
                .TextMatrix(Row, .ColIndex("UnitName")) = .ComboItem
 
        End Select
   
        If Row = .Rows - 1 Then
    
            .Rows = .Rows + 1
        End If

        ReLineGrid
    End With

End Sub

Private Sub ReLineGrid()
    Dim IntCounter As Integer
    IntCounter = 0
    Dim i As Integer

    With Me.Grid

        For i = .FixedRows To .Rows - 1
    
            If .TextMatrix(i, .ColIndex("FromValue")) <> "" Then
                IntCounter = IntCounter + 1
                .TextMatrix(i, .ColIndex("Ser")) = IntCounter
  
            End If

        Next i
   
    End With

    With Me.Grid1

        For i = .FixedRows To .Rows - 1
    
            If .TextMatrix(i, .ColIndex("FromValue")) <> "" Then
                IntCounter = IntCounter + 1
                .TextMatrix(i, .ColIndex("Ser")) = IntCounter
  
            End If

        Next i
   
    End With

End Sub

Public Sub Retrive(Optional Lngid As Long = 0)
    Dim RsDev As ADODB.Recordset
    Dim StrSQL As String
    Dim i As Integer

    'On Error GoTo ErrTrap
    Grid.Clear flexClearScrollable, flexClearEverything
    Grid.Rows = 1
          
    Grid1.Clear flexClearScrollable, flexClearEverything
    Grid1.Rows = 1
          
    If rs.RecordCount < 1 Then
        Exit Sub
    End If

    If rs.EOF Or rs.BOF Then
        Exit Sub
    Else

    End If
 
    Me.TxtSalesAndCollectionPlanId.text = IIf(IsNull(rs("TblSalesAndCollectionPlanId").value), "", rs("TblSalesAndCollectionPlanId").value)
 
    dbRecordDate.value = IIf(IsNull(rs("RecordDate").value), Date, rs("RecordDate").value)
 
    If Not IsNull(rs("planType").value) Then
        opt(rs("planType").value).value = True
    End If

    Dcbranch.BoundText = IIf(IsNull(rs("branchid").value), "", rs("branchid").value)
  
    DCGroup.BoundText = IIf(IsNull(rs("groupid").value), "", rs("groupid").value)
    DCEmp.BoundText = IIf(IsNull(rs("EmpId").value), "", rs("EmpId").value)

    TxtRemarks.text = IIf(IsNull(rs("Remarks").value), 0, rs("Remarks").value)

    StrSQL = " SELECT   * FROM         dbo.TblSalesAndCollectionPlanDetails  "
    StrSQL = StrSQL & "  where sales_OR_Collection=0 and  TblSalesAndCollectionPlanId=" & val(Me.TxtSalesAndCollectionPlanId.text)
    
    Set RsDev = New ADODB.Recordset
    RsDev.Open StrSQL, Cn, adOpenStatic, adLockReadOnly, adCmdText

    If Not (RsDev.BOF Or rs.EOF) Then
        RsDev.MoveFirst
    
        With Me.Grid
    
            .Rows = .FixedRows + RsDev.RecordCount

            For i = .FixedRows To .Rows - 1
            
                .TextMatrix(i, .ColIndex("IntervalID")) = IIf(IsNull(RsDev("IntervalID").value), 0, val(RsDev("IntervalID").value))
            
                .TextMatrix(i, .ColIndex("Value")) = IIf(IsNull(RsDev("Value").value), 0, val(RsDev("Value").value))
             
                .TextMatrix(i, .ColIndex("Remarks")) = IIf(IsNull(RsDev("Remarks").value), "", RsDev("Remarks").value)
            
                RsDev.MoveNext
            Next i
 
        End With

    End If
 
    RsDev.Close
 
    StrSQL = " SELECT   * FROM         dbo.TblSalesAndCollectionPlanDetails  "
    StrSQL = StrSQL & "  where sales_OR_Collection=1 and  TblSalesAndCollectionPlanId=" & val(Me.TxtSalesAndCollectionPlanId.text)
    
    Set RsDev = New ADODB.Recordset
    RsDev.Open StrSQL, Cn, adOpenStatic, adLockReadOnly, adCmdText

    If Not (RsDev.BOF Or rs.EOF) Then
        RsDev.MoveFirst
    
        With Me.Grid1
    
            .Rows = .FixedRows + RsDev.RecordCount

            For i = .FixedRows To .Rows - 1
            
                .TextMatrix(i, .ColIndex("IntervalID")) = IIf(IsNull(RsDev("IntervalID").value), 0, val(RsDev("IntervalID").value))
            
                .TextMatrix(i, .ColIndex("Value")) = IIf(IsNull(RsDev("Value").value), 0, val(RsDev("Value").value))
             
                .TextMatrix(i, .ColIndex("Remarks")) = IIf(IsNull(RsDev("Remarks").value), "", RsDev("Remarks").value)
            
                RsDev.MoveNext
            Next i
 
        End With

    End If
 
    ReLineGrid
    Exit Sub
ErrTrap:
End Sub
 
