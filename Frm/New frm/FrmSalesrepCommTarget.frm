            End If
        
        ElseIf opt(1).value = True Then
 
            If Trim(Me.DCGroup.BoundText) = "" Then
                If SystemOptions.UserInterface = ArabicInterface Then
                    Msg = "ÌÃ» ≈Œ Ì«— «·„Ã„Ê⁄Â..!!"
                Else
