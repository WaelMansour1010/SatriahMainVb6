Private Sub SaveData()
    Dim Msg As String
    Dim RsTemp As New ADODB.Recordset
    Dim StrSQL As String
    Dim BeginTrans As Boolean
    Dim RsDev As ADODB.Recordset
    Dim LngDevID As Long

    'On Error GoTo ErrTrap
    If Me.TxtModFlg.text <> "R" Then
 
        '        If Trim(Me.DCEmp.BoundText) = "" Then
        '            Msg = "íĚČ ĹÎĘíÇŃ ÇáăäĎćČ..!!"
        '            MsgBox Msg, vbOKOnly + vbInformation + vbMsgBoxRight + vbMsgBoxRtlReading, App.Title
        '            DCEmp.SetFocus
        '            SendKeys "{F4}"
        '            Exit Sub
        '        End If
 
    End If

    '-------------------------------------------------------------------------------------------
   
    Cn.BeginTrans
    BeginTrans = True

    If TxtModFlg.text = "N" Then
        rs.AddNew
    ElseIf Me.TxtModFlg.text = "E" Then
    
        '    Cn.Execute "delete tblSalesAndCollectionPlanDetails where TblSalesAndCollectionPlanId=" & Val(Me.TxtSalesAndCollectionPlanId.text)
   
    End If
    
    rs("TblSalesAndCollectionPlanId").value = val(Me.TxtSalesAndCollectionPlanId.text)
    
    If opt(0).value = True Then
        rs("planType").value = 0
        rs("branchid").value = IIf(Me.Dcbranch.BoundText = "", Null, Me.Dcbranch.BoundText)
        rs("groupid").value = Null
        rs("EmpId").value = Null
    ElseIf opt(1).value = True Then
        rs("planType").value = 1
        rs("groupid").value = IIf(Me.DCGroup.BoundText = "", Null, Me.DCGroup.BoundText)
        rs("branchid").value = Null
        rs("EmpId").value = Null
     
    ElseIf opt(2).value = True Then
        rs("planType").value = 2
        rs("EmpId").value = IIf(Me.DCEmp.BoundText = "", Null, Me.DCEmp.BoundText)
        rs("branchid").value = Null
        rs("groupid").value = Null
    
    End If
    
    rs("RecordDate").value = dbRecordDate.value
    rs("Remarks").value = IIf(Me.TxtRemarks.text = "", "", Me.TxtRemarks.text)
 
    rs.update
    
    Set RsDev = New ADODB.Recordset
        
    RsDev.Open "TblSalesAndCollectionPlanDetails", Cn, adOpenStatic, adLockOptimistic, adCmdTable
        
    Dim i As Integer

    With Me.Grid

        For i = 1 To .Rows - 1

            If .TextMatrix(i, .ColIndex("IntervalID")) <> "" Then
         
                RsDev.AddNew
                RsDev("TblSalesAndCollectionPlanId").value = Me.TxtSalesAndCollectionPlanId.text
            
                RsDev("IntervalID").value = val(.TextMatrix(i, .ColIndex("IntervalID")))
                RsDev("Value").value = val(.TextMatrix(i, .ColIndex("Value")))
                RsDev("sales_OR_Collection").value = 0
              
