Private Sub GetStatus(ByVal mCode As Integer)
    Dim s As String
    Dim rsDummy As New ADODB.Recordset
    s = "Select IsNull(ContainerContracts.Status,0) as Status,IsNull(ContainerContracts.EndDate,(Select GetDate())) EndDate From ContainerContracts"
    s = s & " Left Outer join ContainerContractsDet CC "
    s = s & "  On  ContainerContracts.Id = CC.MasterID"
    s = s & " Where CC.FixedAssetsID = " & mCode
    rsDummy.Open s, Cn, adOpenStatic
    If Not rsDummy.EOF Then
        If val(rsDummy!Status & "") = 0 Then
            mStatus = 0
        ElseIf val(rsDummy!Status & "") <> 0 Then
            mStatus = val(rsDummy!Status & "")
        End If
        If DateDiff("d", rsDummy!EndDate, Date) < 0 Then
            mStatus = 0
        ElseIf DateDiff("d", rsDummy!EndDate, Date) > 0 Then
            mStatus = 1
        End If
    Else
        mStatus = 1
    End If
    
End Sub
