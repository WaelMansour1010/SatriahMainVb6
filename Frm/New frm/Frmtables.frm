Private Sub lvwTables_ItemDblClick(Item As vbalListViewLib6.cListItem)
Dim xx As String
If Item.Key <> "" Then
    If Item.backcolor = vbRed Then
        xx = ""
        Dim s As String
        Dim rsDummy As New ADODB.Recordset
        s = "Select Top 1 MM.Id from ContainerContractsRecDet Det Inner Join ContainerContractsRec MM On Det.MasterID = MM.Id"
        s = s & " Where FixedAssetsID = " & val(Item.Key)
        s = s & " Order By RecDate Desc"
        rsDummy.Open s, Cn, adOpenStatic, adLockReadOnly, adCmdText
        If Not rsDummy.EOF Then
            emp_CONTRACT_TYPE.mIndex = 2
            emp_CONTRACT_TYPE.FiLLTXT2 val(rsDummy!ID & "")
            emp_CONTRACT_TYPE.show
        End If
        
        
    ElseIf Item.backcolor = vbGreen Then
        emp_CONTRACT_TYPE.mIndex = 1
        emp_CONTRACT_TYPE.FixedAssetsID = val(Item.Key)
        emp_CONTRACT_TYPE.FixedAssetsName = (Item.Text)
        emp_CONTRACT_TYPE.btn_New_Click 1
        emp_CONTRACT_TYPE.show
        xx = ""
    End If
End If
