Private Sub Retrive_Items(ByVal mIndex As Long)


Dim i As Integer
     Set rsItemDet = New ADODB.Recordset
    Dim StrSQL As String
    StrSQL = "SELECT  " & GetTableName(mIndex) & ".* "
    If mIndex = 31 Then
        StrSQL = StrSQL & " ,TblTypeImage.Name as MasterIDName"
    End If
    StrSQL = StrSQL & " From "
    StrSQL = StrSQL & GetTableName(mIndex)
    If mIndex = 31 Then
        StrSQL = StrSQL & " Inner join TblTypeImage On TblTypeImage.Id = TblTypeImage2.MasterId"
        StrSQL = StrSQL & " Order By TblTypeImage.Id"
    End If
     rsItemDet.Open StrSQL, Cn, adOpenStatic, adLockOptimistic, adCmdText
     grd(mIndex).Rows = 1
    If rsItemDet.RecordCount > 0 Then
        rsItemDet.MoveFirst
        With grd(mIndex)
        .Rows = rsItemDet.RecordCount + 1
         For i = 1 To .Rows - 1
         .TextMatrix(i, .ColIndex("Serial")) = i
         .TextMatrix(i, .ColIndex("id")) = IIf(IsNull(rsItemDet("id").value), "", rsItemDet("id").value)
         .TextMatrix(i, .ColIndex("name")) = IIf(IsNull(rsItemDet("name").value), "", rsItemDet("name").value)
         .TextMatrix(i, .ColIndex("namee")) = IIf(IsNull(rsItemDet("namee").value), "", rsItemDet("namee").value)
        If mIndex = 31 Then
           .TextMatrix(i, .ColIndex("MasterIDName")) = IIf(IsNull(rsItemDet("MasterIDName").value), "", rsItemDet("MasterIDName").value)
            .TextMatrix(i, .ColIndex("MasterId")) = IIf(IsNull(rsItemDet("MasterId").value), "", rsItemDet("MasterId").value)
           End If
           
           If mIndex = 33 Or mIndex = 34 Then
                .TextMatrix(i, .ColIndex("QRCODE")) = IIf(IsNull(rsItemDet("QRCODE").value), "", rsItemDet("QRCODE").value)
           
           End If
            
          rsItemDet.MoveNext
         Next
         End With
    End If
