    TxtInveValue.Text = IIf(IsNull(RsSavRec.Fields("InveValue").value), 0, RsSavRec.Fields("InveValue").value)
    TxtNoCus.Text = IIf(IsNull(RsSavRec.Fields("NoCus").value), 0, RsSavRec.Fields("NoCus").value)
    
    DCboUserName.BoundText = IIf(IsNull(RsSavRec.Fields("UserID").value), "", RsSavRec.Fields("UserID").value)
