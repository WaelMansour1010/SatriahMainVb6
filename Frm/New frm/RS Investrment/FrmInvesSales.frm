Function CheckSales() As Boolean
Dim Rs8 As ADODB.Recordset
Set Rs8 = New ADODB.Recordset
Dim Sql As String
Sql = " SELECT     ID, InvesID"
Sql = Sql & " From dbo.TblSaleBilllInvestmentDet"
Sql = Sql & " Where (InvesID = " & val(DcbInvise.BoundText) & ")"
Rs8.Open Sql, Cn, adOpenStatic, adLockOptimistic, adCmdText
If Rs8.RecordCount > 0 Then
CheckSales = True
Else
CheckSales = False
End If
End Function

Function CheckRepeat() As Boolean
Dim Rs8 As ADODB.Recordset
Set Rs8 = New ADODB.Recordset
Dim Sql As String
Sql = " SELECT     ID, InvesID"
Sql = Sql & " From dbo.TblInvesOpenSales"
Sql = Sql & " Where (InvesID = " & val(DcbInvise.BoundText) & ")and id <> " & val(TxtSerial1.Text) & ""

Rs8.Open Sql, Cn, adOpenStatic, adLockOptimistic, adCmdText
If Rs8.RecordCount > 0 Then
CheckRepeat = True
Else
CheckRepeat = False
End If
End Function

Function GetNoCus() As Double
Dim Rs8 As ADODB.Recordset
Set Rs8 = New ADODB.Recordset
Dim Sql As String
Sql = " SELECT     InvesID, CusID"
Sql = Sql & " From dbo.TblTransactionInvest"
Sql = Sql & " Where (InvesID = " & val(DcbInvise.BoundText) & ")"
Sql = Sql & " GROUP BY InvesID, CusID"
Rs8.Open Sql, Cn, adOpenStatic, adLockOptimistic, adCmdText
If Rs8.RecordCount > 0 Then
GetNoCus = Rs8.RecordCount
Else
GetNoCus = 0
End If
End Function
