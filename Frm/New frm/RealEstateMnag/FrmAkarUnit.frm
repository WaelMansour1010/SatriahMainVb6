            Msg = "عفوا لقد تم حذف هذا السجل التالى" & CHR(13)
            Msg = Msg & "من قبل مستخدم أخر على الشبكة " & CHR(13)
            Msg = Msg & "سوف يتم تحديث البيانات"
            MsgBox Msg, vbExclamation + vbMsgBoxRight + vbMsgBoxRtlReading + vbOKOnly, App.title
            RsSavRec.Requery
            Resume BegnieWork
    End Select

End Sub

