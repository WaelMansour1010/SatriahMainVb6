Private Sub BtnUpdate_Click()
    On Error GoTo ErrTrap
    Dim Msg As String
    Dim FristCount As Long
    Dim LastCount As Long
    FristCount = RsSavRec.RecordCount
    RsSavRec.Requery
    LastCount = RsSavRec.RecordCount
    BtnUndo_Click

    If FristCount = LastCount Then
        Msg = "لا توجد بيانات جديدة"
    Else
        Msg = "عدد السجلات قبل التحديث" & vbCrLf & FristCount & vbCrLf & "عدد السجلات بعد التحديث" & vbCrLf & LastCount
        
        If LastCount > FristCount Then
            Msg = Msg + vbCrLf & "عدد السجلات الجديدة" & vbCrLf & LastCount - FristCount
        Else
            Msg = Msg + vbCrLf & "عدد السجلات المحذوفة" & vbCrLf & FristCount - LastCount
        End If
    End If

    MsgBox Msg, vbOKOnly + vbMsgBoxRight + vbInformation, App.title
ErrTrap:
End Sub

Private Sub Form_Load()
    On Error GoTo ErrTrap
    Dim i As Integer
    Dim My_SQL As String
    ScreenNameArabic = " انواع الوحدات  "
    ScreenNameEnglish = " Customer and   Supplier Types"
    RegisterLogInOut Me.Name, ScreenNameArabic, ScreenNameEnglish, "1"
    
           
     TabMain.TabVisible(1) = False
     
     TabMain.TabVisible(0) = False
     mIndex2 = mIndex - 1
     TabMain.TabVisible(mIndex) = True
     TabMain.CurrTab = mIndex
     
    If mIndex = 0 Then
        My_SQL = "TblAkarUnit"
        Set BKGrndPic = New ClsBackGroundPic
        Set RsSavRec = New ADODB.Recordset
        RsSavRec.CursorLocation = adUseClient
        RsSavRec.Open My_SQL, Cn, adOpenKeyset, adLockPessimistic, adCmdTableDirect
        Me.TxtModFlg.Text = "R"
        Me.Width = Grid.Width + 400
        Resize_Form Me
        'load tblUsers -----------------------------------------------
        My_SQL = "select UserID,UserName From tblUsers "
        fill_combo DCUser, My_SQL
    
        FillGridWithData
    
        With Me.Grid
            .Cell(flexcpPicture, 0, .ColIndex("name")) = Me.GrdImageList.ListImages("Vac_Name").ExtractIcon
            .Cell(flexcpPicture, 0, .ColIndex("Ser")) = Me.GrdImageList.ListImages("Ser").ExtractIcon
    
            For i = 0 To .Cols - 1
                .Cell(flexcpPictureAlignment, 0, i) = flexPicAlignRightCenter
            Next
       
            .ExtendLastCol = True
            .WallPaper = BKGrndPic.Picture
            .RowHeight(-1) = 300
        End With
        
        BtnFirst_Click
    ElseIf mIndex = 1 Then
          DCboType.AddItem "عرض"
        DCboType.AddItem "طلب"
      
        
        
        DCboCashType.AddItem "نقدي"
        DCboCashType.AddItem "تقسيط"
        DCboCashType.AddItem "نقدي وتقسيط"
        
        
         
         
         
        Dcombos.GetUsers Me.DCboUserName(1)
       
        Dcombos.getAkarUnit Me.cmbAkarUnit2
        
        Dcombos.GetCountriesNames cmbCountries
        Dcombos.getCountriesGovernments cmbCountriesGovernments
        Dcombos.GetCountrieshay cmbCountrieshay
        
        Dcombos.GetFinished cmbFinished
        Dcombos.GetTblView cmbView
         
        
        
    End If
    ShowTip

    If SystemOptions.UserInterface = EnglishInterface Then
        SetInterface Me
        ChangeLang
    End If

    If OPEN_NEW_SCREEN = True Then
        btnNew_Click
    End If

ErrTrap:
End Sub

