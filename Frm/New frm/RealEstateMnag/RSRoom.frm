Private Sub btnSave_Click()
    On Error GoTo ErrTrap
    Dim Msg As String
    Dim StrVacCode As String
    Dim StrVacName As String
    Dim CtrlTxt As Control
    '---------------------- check if data Vaclete -----------------------

    For Each CtrlTxt In Me.Controls

        If TypeOf CtrlTxt Is TextBox Or TypeOf CtrlTxt Is ComboBox Then
            If CtrlTxt.text = "" And CtrlTxt.Tag <> "" And CtrlTxt.Enabled = True Then
                MsgBox CtrlTxt.Tag, vbOKOnly + vbMsgBoxRight, App.title
                CtrlTxt.SetFocus
                Exit Sub
            End If
        End If

    Next

    '------------------------------ check if Empcode exist ----------------------

    StrVacName = IsRecExist("streets", "GovernmentName", Trim(TxtVacName.text), "GovernmentName", "Vac_ID<>'" & Trim(TxtVac_ID.text) & "'")

    If StrVacName <> "" Then
        Msg = "ŠřŌ ”»ř  ”ŐŪŠ Ś–« «Ššśŕ „š ř»Š"
        MsgBox Msg, vbOKOnly + vbMsgBoxRight, App.title
        TxtVacName.SetFocus
        Exit Sub
    End If

    If val(Me.DcboGovernmentID.BoundText) = 0 Then
        Msg = "„š ›÷ŠŖ «ő — «”„ «Š„Õ«›Ŕ…....!!!!"
        MsgBox Msg, vbOKOnly + vbMsgBoxRight, App.title
        DcboGovernmentID.SetFocus
        Exit Sub
    End If

    ' -------------------------------------- txtmodflg type -------------------
    Select Case Me.TxtModFlg.text

            '------------------------------ new record ----------------------------
        Case "N"
            '------------------------- save record -----------------------------
            AddNewRec
            BtnLast_Click

        Case "E"
            '----------------------------- save edit -------------------------------
            FiLLRec
    End Select

    Exit Sub
ErrTrap:
    MsgBox "Śš«Ŗ őō√ „« ›Ū ŇŌő«Š «Š»Ū«š« ", vbOKOnly + vbMsgBoxRight, App.title

