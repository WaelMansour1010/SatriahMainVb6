Sub RetriveEmployeeInfo(Optional Emp_id As Double = 0)
Dim Sql As String
Dim Rs2 As ADODB.Recordset
Set Rs2 = New ADODB.Recordset
Sql = "Select * from TblEmployee where Emp_ID=" & Emp_id & " "
Rs2.Open Sql, Cn, adOpenStatic, adLockOptimistic, adCmdText
If Rs2.RecordCount > 0 Then
TxtNam.Text = IIf(IsNull(Rs2("Emp_Name").value), "", Rs2("Emp_Name").value)
TxtNameE.Text = IIf(IsNull(Rs2("Emp_Namee").value), "", Rs2("Emp_Namee").value)
