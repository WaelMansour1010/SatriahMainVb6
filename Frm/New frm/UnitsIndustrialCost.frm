Private Sub ReLineGrid()
    Dim IntCounter As Integer
    IntCounter = 0
    Dim i As Integer

    With Me.Grid

        For i = .FixedRows To .Rows - 1
    
            If .TextMatrix(i, .ColIndex("TBLProductionElementsId")) <> "" Then
                IntCounter = IntCounter + 1
                .TextMatrix(i, .ColIndex("Ser")) = IntCounter
  
            End If

        Next i

        If .Rows > 1 Then
            TXTEstimatedTotalCost = .Aggregate(flexSTSum, .FixedRows, .ColIndex("Cost"), .Rows - 1, .ColIndex("Cost"))
        Else
            TXTEstimatedTotalCost = 0
        End If

    End With

    With Me.GRID1

        For i = .FixedRows To .Rows - 1
    
            If .TextMatrix(i, .ColIndex("FromValue")) <> "" Then
                IntCounter = IntCounter + 1
                .TextMatrix(i, .ColIndex("Ser")) = IntCounter
  
            End If

        Next i
   
    End With

End Sub

Public Sub Retrive(Optional Lngid As Long = 0)
    Dim RsDev As ADODB.Recordset
    Dim StrSQL As String
    Dim i As Integer

    'On Error GoTo ErrTrap
    Grid.Clear flexClearScrollable, flexClearEverything
    Grid.Rows = 1
          
    If rs.RecordCount < 1 Then
        Exit Sub
    End If

    If rs.EOF Or rs.BOF Then
        Exit Sub
    Else

    End If
 
    Me.TxtUnitsIndustrialCost.text = IIf(IsNull(rs("id").value), "", rs("id").value)
    Me.TXTEstimatedTotalCost.text = IIf(IsNull(rs("EstimatedTotalCost").value), 0, rs("EstimatedTotalCost").value)

    DcCurrency.BoundText = IIf(IsNull(rs("Currencyid").value), "", rs("Currencyid").value)
    DCUnits.BoundText = IIf(IsNull(rs("Unitid").value), "", rs("Unitid").value)

    TxtRemarks.text = IIf(IsNull(rs("Remarks").value), 0, rs("Remarks").value)
 
    StrSQL = "SELECT     dbo.UnitsIndustrialCostDetails.Remarks, dbo.UnitsIndustrialCostDetails.Cost, dbo.UnitsIndustrialCostDetails.TBLProductionElementsId, "
    StrSQL = StrSQL & "   dbo.UnitsIndustrialCostDetails.UnitsIndustrialCostId , dbo.UnitsIndustrialCostDetails.id, dbo.TBLProductionElements.name, dbo.TBLProductionElements.nameE"
    StrSQL = StrSQL & "  FROM         dbo.UnitsIndustrialCostDetails INNER JOIN"
    StrSQL = StrSQL & "  dbo.TBLProductionElements ON dbo.UnitsIndustrialCostDetails.TBLProductionElementsId = dbo.TBLProductionElements.TBLProductionElementsId"
    StrSQL = StrSQL & "  WHERE     (dbo.UnitsIndustrialCostDetails.UnitsIndustrialCostId = " & val(Me.TxtUnitsIndustrialCost.text) & ")"

    Set RsDev = New ADODB.Recordset
    RsDev.Open StrSQL, Cn, adOpenStatic, adLockReadOnly, adCmdText

    If Not (RsDev.BOF Or rs.EOF) Then
        RsDev.MoveFirst
    
        With Me.Grid
    
            .Rows = .FixedRows + RsDev.RecordCount

            For i = .FixedRows To .Rows - 1
            
                .TextMatrix(i, .ColIndex("TBLProductionElementsId")) = IIf(IsNull(RsDev("TBLProductionElementsId").value), 0, val(RsDev("TBLProductionElementsId").value))
            
                If SystemOptions.UserInterface = ArabicInterface Then
                    .TextMatrix(i, .ColIndex("TBLProductionElementsName")) = IIf(IsNull(RsDev("name").value), "", RsDev("name").value)
                Else
                    .TextMatrix(i, .ColIndex("TBLProductionElementsName")) = IIf(IsNull(RsDev("namee").value), "", RsDev("namee").value)
                End If
            
                .TextMatrix(i, .ColIndex("Cost")) = IIf(IsNull(RsDev("Cost").value), 0, val(RsDev("Cost").value))
             
                .TextMatrix(i, .ColIndex("Remarks")) = IIf(IsNull(RsDev("Remarks").value), "", RsDev("Remarks").value)
            
                RsDev.MoveNext
            Next i
 
        End With

    End If
 
    ReLineGrid
    Exit Sub
ErrTrap:
End Sub
 
