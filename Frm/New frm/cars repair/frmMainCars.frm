Private Sub Form_Load()
Me.left = mdifrmmain.Width - 4000
Me.top = 0
  '  Me.Width = 6000
  ' Me.Height = (mdifrmmain.Height)
  Dim cOptions As ClsCompanyInfo
    Set cOptions = New ClsCompanyInfo
    If SystemOptions.UserInterface = ArabicInterface Then
    Label8.Caption = cOptions.ArabCompanyName & Chr(13) & CurrentBranchName
Else
Label8.Caption = cOptions.EngCompanyName & Chr(13) & CurrentBranchNameE
End If
'Image1.Width = Me.Width
