Private Sub ALLButton1_Click()
    Adodc1.Recordset.AddNew
    Adodc1.Recordset.Fields!spec_id = Combo1.ListIndex
    Adodc1.Recordset.Fields!spec_name = Combo1.text
    Adodc1.Recordset.Fields!mister_id = Combo2.ListIndex
    Adodc1.Recordset.Fields!mister_name = Combo2.text
    Adodc1.Recordset.update
End Sub

Private Sub ALLButton3_Click()
    Adodc2.Recordset.AddNew
    Adodc2.Recordset.Fields!spec_id = Combo4.ListIndex
    Adodc2.Recordset.Fields!spec_name = Combo4.text

    Adodc2.Recordset.Fields!lec_no = Combo5.text
