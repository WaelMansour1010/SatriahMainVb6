Function CalcContractIntervalAuto()
If Me.TxtModFlg2(mIndex) = "R" Or val(Contract_period_no.Text) = 0 Then Exit Function

EndDate.value = calcenaddate(StrDate.value, val(Contract_period_no.Text), val(Contract_period.ListIndex))
  
Dim i As Long
Dim MDate As Date
For i = 1 To grd2(mIndex).Rows - 1
    If grd2(mIndex).TextMatrix(i, grd2(mIndex).ColIndex("FixedAssetsID")) <> "" Then
        MDate = calcenaddate(Date, val(Contract_period_no.Text), val(Contract_period.ListIndex), i)
        
    End If
Next


End Function

Private Function calcenaddate(Optional ByVal StartDate As Date = "1-1-1900", Optional ByVal interval As Integer = -1, Optional ByVal intervalvalindex As Integer = -1, Optional ByVal i As Long = -1) As Date
Dim intervalchar As String
If intervalvalindex = 0 Then
        intervalchar = "M"
 ElseIf intervalvalindex = 1 Then
      intervalchar = "YYYY"
ElseIf intervalvalindex = 2 Then
      intervalchar = "D"
        
        
        
Else
           intervalchar = "YYYY"
End If
If i = -1 Then
    calcenaddate = DateAdd(intervalchar, interval, StartDate)
Else
    Dim mFromDate As String
    Dim mToDate As String
    mFromDate = grd2(mIndex).TextMatrix(i, grd2(mIndex).ColIndex("FromDate"))
    If mFromDate = "" Then
        grd2(mIndex).TextMatrix(i, grd2(mIndex).ColIndex("FromDate")) = StrDate.value
        grd2(mIndex).TextMatrix(i, grd2(mIndex).ColIndex("ToDate")) = EndDate.value
    End If
    mFromDate = grd2(mIndex).TextMatrix(i, grd2(mIndex).ColIndex("FromDate"))
    mToDate = grd2(mIndex).TextMatrix(i, grd2(mIndex).ColIndex("ToDate"))
    grd2(mIndex).TextMatrix(i, grd2(mIndex).ColIndex("NoDays")) = DateDiff(intervalchar, mFromDate, mToDate)
    grd2(mIndex).TextMatrix(i, grd2(mIndex).ColIndex("NoDays")) = DateDiff("D", mFromDate, mToDate)
    calcenaddate = grd2(mIndex).TextMatrix(i, grd2(mIndex).ColIndex("ToDate"))
End If


End Function

