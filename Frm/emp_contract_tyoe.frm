    If FristCount = LastCount Then
        Msg = "бЗ КжМП ИнЗдЗК МПнПЙ"
    Else
        Msg = "ЪПП ЗбУМбЗК ЮИб ЗбКНПнЛ" & vbCrLf & FristCount & vbCrLf & "ЪПП ЗбУМбЗК ИЪП ЗбКНПнЛ" & vbCrLf & LastCount
        
