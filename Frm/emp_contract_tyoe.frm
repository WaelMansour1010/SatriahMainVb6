Private Sub GetNoOfRD()
If cmbRecType(mIndex).ListIndex <> 0 Then Exit Sub
Dim s As String
Dim rsDummy As New ADODB.Recordset
Dim mCode As Integer, i As Integer, mLineID As Integer
For i = 1 To grd2(2).Rows - 1
    mCode = val(grd2(2).TextMatrix(i, grd2(2).ColIndex("FixedAssetsID")))
    mLineID = val(grd2(2).TextMatrix(i, grd2(2).ColIndex("LineID")))
    If mCode = 0 Then GoTo NextRow
        s = "SELECT Count(IsNull(Id,0)) CC"
    s = s & " From ContainerContractsDet"
    s = s & " WHERE  FixedAssetsID IN (SELECT FixedAssetsID"
    s = s & "                           FROM   ContainerContractsRecDet AS ccrd"
    s = s & "                                  INNER JOIN ContainerContractsRec"
    s = s & "                                       ON  ContainerContractsRec.ID = ccrd.MasterID"
    s = s & "                           WHERE  ContainerContractsRec.ContractNo = ContainerContractsDet.MasterID "
    s = s & " and   ContainerContractsDet.Id  = " & mLineID & ")                        "
    
    's =s & " and ContainerContractsRec.Id <> " & val(TxtSerial1(2)) & ")"
                              
    s = s & " and FixedAssetsID =" & mCode & " AND MasterID = " & val(txtContractNo)
    
    s = " SELECT COUNT(ContainerContractsRecDet.Id) dd"
    s = s & " From ContainerContractsRecDet"
    s = s & " INNER JOIN ContainerContractsRec"
    s = s & " ON  ContainerContractsRec.ID =    ContainerContractsRecDet.MasterID"
    s = s & " Where ContainerContractsRec.ContractNo = " & val(txtContractNo)
    s = s & " AND FixedAssetsID = " & mCode
    s = s & " and   ContainerContractsRecDet.Id  <> " & mLineID
    If Me.TxtModFlg2(mIndex).Text <> "N" Then
        s = s & " and ContainerContractsRec.Id <> " & val(TxtSerial1(2))
    End If
    's = s & " GROUP BY Id"
    rsDummy.Open s, Cn, adOpenStatic, adLockReadOnly, adCmdText
    If Not rsDummy.EOF Then
        grd2(2).TextMatrix(i, grd2(2).ColIndex("RepliesNo")) = val(rsDummy!dd & "") + 1
    Else
        grd2(2).TextMatrix(i, grd2(2).ColIndex("RepliesNo")) = 1
    End If
    rsDummy.Close
NextRow:
Next
 
End Sub
