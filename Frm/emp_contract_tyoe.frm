Private Sub cmdInsertAll_Click()
    Dim StrSQL  As String
    If txtTradingContractID.Text = "" Then
    MsgBox "ЗОКС ЗбЗКЭЗЮне ЗжбЗ "
    Exit Sub
    End If
    StrSQL = "Select dbo.Tbl_TradingContractDet.ID BDet_BandNo,  Tbl_TradingContractDet.TContractDet_Qun BDet_Qun, dbo.Tbl_TradingContractDet.TContractDet_TContractID, dbo.TblProcessDEF.ProcessName Name,TblProcessDEF.TblProcessDEFID TConID,"
    StrSQL = StrSQL & " dbo.TblProcessDEF.ProcessNameE NameE,IsNull(Tbl_TradingContractDet.TContractDet_SalPrice,0) + IsNull(Tbl_TradingContractDet.TContractDet_InstallPrice,0)  BDet_Price, IsNull(Tbl_TradingContractDet.TContractDet_TotalSalPrice,0) + IsNull(Tbl_TradingContractDet.TContractDet_TotalInstallPrice,0)  Total, dbo.TblProcessDEF.interval, dbo.TblProcessDEF.IntervalID,"
    StrSQL = StrSQL & " TContractDet_SalPrice SalPrice,TContractDet_InstallPrice InstallPrice,TContractDet_TotalSalPrice TotalSalPrice,TContractDet_TotalInstallPrice TotalInstallPrice"
    StrSQL = StrSQL & " FROM  dbo.Tbl_TradingContractDet INNER JOIN"
