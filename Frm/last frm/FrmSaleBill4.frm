Private Function GetSphCylID(ByVal mType As Integer, ByVal MSTR As String) As Long

Dim s As String
If mType = 0 Then
    s = "Select Id from SPHTable Where SPHT Like '" & Trim(MSTR) & "'"
ElseIf mType = 1 Then
    s = "Select Id from CLYTable Where CLYT Like '" & Trim(MSTR) & "'"
End If
Dim rsDummy As ADODB.Recordset
Set rsDummy = New ADODB.Recordset
rsDummy.Open s, Cn, adOpenKeyset, adLockReadOnly
If Not rsDummy.EOF Then
    GetSphCylID = val(rsDummy!ID & "")
End If
End Function


