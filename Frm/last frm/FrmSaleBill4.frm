Private Sub lbl_DblClick(Index As Integer)

Dim SPH As Double
Dim Cyl As Double
Dim axe As Double

Select Case Index
Case 162

ReverseMedical val(DCBoMain(2).Text), val(DCBoMain(3).Text), val(DCBoMain(4).Text), SPH, Cyl, axe
DCBoMain(2).Text = IIf(SPH > 0, "+" & Format(SPH, "0.00"), Format(SPH, "0.00"))
DCBoMain(3).Text = IIf(Cyl > 0, "+" & Format(Cyl, "0.00"), Format(Cyl, "0.00"))
DCBoMain(4).Text = axe


Case 162

ReverseMedical val(DCBoMain(5).Text), val(DCBoMain(6).Text), val(DCBoMain(7).Text), SPH, Cyl, axe
DCBoMain(5).Text = IIf(SPH > 0, "+" & Format(SPH, "0.00"), Format(SPH, "0.00"))
DCBoMain(6).Text = IIf(Cyl > 0, "+" & Format(Cyl, "0.00"), Format(Cyl, "0.00"))
DCBoMain(7).Text = axe


