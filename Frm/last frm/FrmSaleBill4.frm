Private Sub XPChkPayType_Click(Index As Integer)
    On Error GoTo ErrTrap

    Select Case Index

        Case 0

            If XPChkPayType(0).value = Checked Then
                If Me.TxtModFlg.Text = "N" Then
                    XPTxtValue(0).Text = ""
                    XPTxtSerial(0).Text = ""
