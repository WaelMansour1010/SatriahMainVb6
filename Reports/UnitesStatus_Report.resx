  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>SELECT DISTINCT 
    PropertyDetail.Id AS PropertyDetailId, 
    PropertyDetail.PropertyUnitNo, 
    PropertyDetail.IsDeleted, 
    PropertyDetail.StatusId, 
    PropertyRenter.ArName AS RenterName, 
    Property.ArName AS PropertyName, 
    LatestContract.DocumentNumber AS ContractNo, 
    LatestContract.VoucherDate AS ContractDate, 
    LatestContract.RentValue AS ContractRentValue, 
    PropertyOwner.ArName AS OwnerName, 
    Property.Code AS PropertyCode, 
    Property.Id AS PropertyId, 
    PropertyDetail.RoomsNo, 
    PropertyDetail.Floor, 
    PropertyDetail.HallsNo, 
    PropertyDetail.IsFurnishing, 
    CASE 
        WHEN PropertyDetail.StatusId = 1 THEN N'مؤجرة'
        WHEN PropertyDetail.StatusId = 2 THEN N'متاحة'
        ELSE N'غير معروفة'
    END AS StatusDescription, 
    PropertyUnit.Code AS UnitCode, 
    PropertyUnit.ArName AS UnitName, 
    PropertyUnitType.ArName AS UnitTypeName, 
    PropertyType.ArName AS PropertyTypeName, 
    PropertyDetail.Area, 
    PropertyDetail.Notes, 
    Department.ArName AS DepartmentName,
	Department.Id DepartmentID,
    LatestTermination.DocumentNumber AS TerminationDocumentNo,
    LatestTermination.VoucherDate AS TerminationDate
FROM 
    PropertyDetail 
INNER JOIN 
    Property ON PropertyDetail.MainDocId = Property.Id AND PropertyDetail.IsDeleted = 0 
LEFT OUTER JOIN 
    Department ON Property.DepartmentId = Department.Id 
LEFT OUTER JOIN 
    PropertyOwner ON Property.PropertyOwnerId = PropertyOwner.Id 
LEFT OUTER JOIN 
    PropertyUnitType ON PropertyDetail.PropertyUnitTypeId = PropertyUnitType.Id 
LEFT OUTER JOIN 
    PropertyType ON Property.PropertyTypeId = PropertyType.Id 
LEFT OUTER JOIN 
    PropertyUnit ON PropertyDetail.Id = PropertyUnit.Id 
LEFT OUTER JOIN 
    (
        -- تحديد أحدث عقد لكل وحدة
        SELECT 
            PC1.PropertyUnitId, 
            PC1.DocumentNumber, 
            PC1.VoucherDate, 
            PC1.RentValue, 
            PC1.PropertyRenterId,
            PC1.Id AS ContractId
        FROM PropertyContract AS PC1
        INNER JOIN (
            SELECT PropertyUnitId, MAX(VoucherDate) AS LatestVoucherDate
            FROM PropertyContract
            GROUP BY PropertyUnitId
        ) AS PC2 
        ON PC1.PropertyUnitId = PC2.PropertyUnitId AND PC1.VoucherDate = PC2.LatestVoucherDate
    ) AS LatestContract 
    ON PropertyDetail.Id = LatestContract.PropertyUnitId 
LEFT OUTER JOIN 
    (
        -- تحديد آخر تصفية لكل عقد
        SELECT 
            PCT1.PropertyContractId, 
            PCT1.VoucherDate, 
            PCT1.DocumentNumber
        FROM PropertyContractTermination AS PCT1
        INNER JOIN (
            SELECT PropertyContractId, MAX(VoucherDate) AS LatestTerminationDate
            FROM PropertyContractTermination
            GROUP BY PropertyContractId
        ) AS PCT2 
        ON PCT1.PropertyContractId = PCT2.PropertyContractId AND PCT1.VoucherDate = PCT2.LatestTerminationDate
    ) AS LatestTermination 
    ON LatestContract.ContractId = LatestTermination.PropertyContractId
LEFT OUTER JOIN 
    PropertyRenter ON LatestContract.PropertyRenterId = PropertyRenter.Id
WHERE     PropertyDetail.IsDeleted = 0
AND (ISNULL(@PropertyId2, 0) = 0 OR Property.Id = @PropertyId2)
And (ISNULL(@DepartmentId, 0) = 0 OR Department.Id = @DepartmentId)
AND (ISNULL(@PropertyRenterId, 0) = 0 OR PropertyRenter.Id = @PropertyRenterId)
AND (ISNULL(@IsFree, 0) = 1 OR PropertyDetail.StatusId = 1)

AND (ISNULL(@IsFree2, 0) = 1 OR PropertyDetail.StatusId = 2)

--AND (ISNULL(@PropertyId, 0) = 0 OR Property.Id = @PropertyId)</value>
